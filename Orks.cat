  <sharedProfiles>
    <profile name="WAAAGH!" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="c9f0-afe5-0f2c-c9b1">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">While your infantry units are within 12” of this unit, they gain the following ability:


WAAAAGH!: For each attack that targets this unit, reroll Resilient rolls of 1 for that attack. For each melee attack this unit makes, reroll a Wound Roll of 1 for that attack.</characteristic>
      </characteristics>
    </profile>
    <profile name="Solid Greenskin" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="c35f-6848-d4c4-faeb">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">For each attack that targets this unit, the Wound Roll for that attack is worsened by 1. If that attack is a SW, add 1 to resilient rolls for that attack. This unit cannot be in cover for enemy attacks.</characteristic>
      </characteristics>
    </profile>
    <profile name="Everyone! Ge’ In ‘ere!" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="ad82-3c2d-6494-820e">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">While this unit is in engagement range of any enemy unit, your infantry units within 24” of this unit gain WAAAAGH!.</characteristic>
      </characteristics>
    </profile>
  </sharedProfiles>
  <sharedRules>
    <rule name="Dakka" id="0c95-a6ed-a147-6b41" hidden="false">
      <description>For each of this weapon’s attacks, a Hit Roll of 6 for that attack causes 2 additional hits.</description>
    </rule>
  </sharedRules>
