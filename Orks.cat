      <selectionEntries>
        <selectionEntry type="upgrade" import="true" name="Psychic Powers" hidden="false" id="0f12-5dc4-407e-9ee9">
          <constraints>
            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="19b7-5f5c-c419-5514-min" includeChildSelections="false"/>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="19b7-5f5c-c419-5514-max" includeChildSelections="false"/>
          </constraints>
          <profiles>
            <profile name="1 Jabbin’ Fingerz" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="9624-b9b2-780c-6b5a">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select an infantry enemy unit with 16” of and visible to this unit. The selected unit suffers D3 SW and until the end of the battle round, for each attack made by that unit, the Hit Roll of that attack is worsened by 1.</characteristic>
              </characteristics>
            </profile>
            <profile name="2 ‘ere We Go!" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="17da-6df2-15cc-facd">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Until the next time this unit Activates or dies, after any of your ORK BOYZ units Activate within 8” of this unit, roll a D3. That unit’s M is improved by that much until the End step.</characteristic>
              </characteristics>
            </profile>
            <profile name="3 Deyz Lucky" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="faef-e547-26cc-3b7b">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select one of your infantry units within 12” of this unit. Until the next time this unit Activates or dies, for each attack that targets that unit, you may reroll a Resilient roll for that attack.</characteristic>
              </characteristics>
            </profile>
            <profile name="4 Da Jump" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="b3dc-36f5-f41f-fc2d">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select one of your infantry units within 12” of this unit. The selected unit may Fall Back up to 5D6” (instead of its normal M). For that move, the models may move over terrain and enemy models as if they were not there.</characteristic>
              </characteristics>
            </profile>
            <profile name="5 Iz Gonna Squig Ya" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="d2d6-a27f-1fa7-2479">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select one visible enemy unit within 16” of this unit. The selected unit suffers 2D3 SW. Then, if one or more models die as a result of those SW, the selected unit suffers D6+2 SW.</characteristic>
              </characteristics>
            </profile>
            <profile name="6 Frazzle" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="d7e3-c08c-7f68-0ea5">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select one enemy unit within 16” and visible to this unit and up to two enemy units within 8” of that enemy unit. For each of the selected units, that unit suffers D6 SW.</characteristic>
              </characteristics>
            </profile>
          </profiles>
        </selectionEntry>
      </selectionEntries>
    </selectionEntry>
