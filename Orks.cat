          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">For each Advance Roll made for your other units within 16” of this unit, roll an additional D6 for that Advance Roll and discard the lowest result.</characteristic>
          </characteristics>
        </profile>
        <profile name="Get Da Good Bitz" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="5f3d-e588-9eae-0bd0">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After this unit’s End step, if this unit is not within 4” horizontally of an objective, this unit may capture an objective that it passed within 4” horizontally of this turn (capture rules still apply)</characteristic>
          </characteristics>
        </profile>
      </profiles>
