        <profile name="5 Vulkan’s Anvil" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="true" id="0e16-c450-6d1a-1385">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Until the next time this unit is Activated, it gains Resilient 5+ and, for each attack with Ignores Cover that targets this unit, add 1 to Resilient Rolls for that attack.</characteristic>
