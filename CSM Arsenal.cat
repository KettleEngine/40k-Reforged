        <profile name="No Witnesses" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="e026-530a-baa5-654c">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After this unit’s Attacks step, for each enemy unit that died this turn, roll 1 D6. On a 6, you may remove this unit from the battlefield and place it into reserves.</characteristic>
          </characteristics>
        </profile>
