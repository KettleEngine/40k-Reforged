          <characteristics>
            <characteristic name="Must Attach to" typeId="2c63-5e3f-9132-459d">This unit must attach to either:
a) HEAVY INTERCESSORS
b) ERADICATORS
c) AGGRESSORS</characteristic>
          </characteristics>
        </profile>
        <profile name="Know The Enemy" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="0063-0e87-3d4e-b224">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After an enemy infantry unit dies within 12&quot; of this unit, you may &apos;use the vivispectrum&apos;. If you do, for the rest of the battle, for each attack made for this unit that targets an infantry unit, reroll a Wound Roll of 1 for that attack.</characteristic>
          </characteristics>
        </profile>
        <profile name="Biologis Knowledge" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="25c1-90b8-bdd0-ddb7">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">For each attack made for this unit that targets an infantry unit, a Hit Roll of 6 causes that attack to always wound.</characteristic>
          </characteristics>
        </profile>
      </profiles>
