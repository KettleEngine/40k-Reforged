          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">While this unit is the closest enemy unit to the active unit, add 1 to Resilient rolls for this unit.</characteristic>
          </characteristics>
        </profile>
        <profile name="Great Butchery" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="91c6-4cce-ff7a-8e09">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">While this unit is within engagement range of any enemy unit and none of your other units are within 5” of this unit, for each of this unit’s attacks which target that enemy unit, that attack gains Shred.</characteristic>
          </characteristics>
