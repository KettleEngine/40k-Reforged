          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After this unit finishes a March, each enemy unit within 7” suffers X Suppression where X is equal to the number of models in this unit.</characteristic>
          </characteristics>
        </profile>
