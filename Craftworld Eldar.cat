        <profile name="Path of the Outcast" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="6418-1756-58c6-0c46">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After each enemy unit’s Move step, if the active unit is within 24” of and visible to this unit, you may roll a D6. On a 5+, this unit Repositions. During that Reposition, this unit&apos;s models may ignore vertical distances.</characteristic>
          </characteristics>
        </profile>
