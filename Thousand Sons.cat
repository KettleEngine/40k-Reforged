    <selectionEntry type="upgrade" import="true" name="Cabalistic Rituals" hidden="false" id="20ae-74f3-a7a2-0f22">
      <profiles>
        <profile name="Cabalistic Rituals" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="3fc0-f99e-3c3d-11d2">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">While your active unit is within 18” of this unit, that unit gains the following abilities:


Arcane Endowment: For each Psychic Test this unit makes, add 1 D6 to that Psychic Test.


Ruinous Spellcraft: For each SW an enemy unit suffers, that SW gains Pierce.</characteristic>
          </characteristics>
        </profile>
      </profiles>
