    <selectionEntry type="upgrade" import="true" name="Psychic Powers of the Hive Mind (Reference)" hidden="false" id="7d0d-f616-5476-3f2c" sortIndex="-3">
      <constraints>
        <constraint type="max" value="1" field="selections" scope="force" shared="true" id="77b1-e9e5-dd30-419b" includeChildSelections="false"/>
        <constraint type="min" value="1" field="selections" scope="force" shared="true" id="f24b-2f2f-d8b0-712f" includeChildSelections="false"/>
        <constraint type="max" value="1" field="selections" scope="force" shared="true" id="385e-53ca-62e9-1f16" includeChildSelections="false"/>
      </constraints>
      <categoryLinks>
        <categoryLink name="Configuration" hidden="false" id="f18d-7987-3da9-54a6" targetId="9cd6-0442-3f35-6b52" primary="true"/>
      </categoryLinks>
      <profiles>
        <profile name="1 Synaptic Surge" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="213a-9ef6-16d1-5590">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Until the end of the next time this unit is Activated or dies, you may reroll Advance Rolls made for friendly units with Adaptive Bioform within 12” of this unit.</characteristic>
          </characteristics>
        </profile>
        <profile name="2 Psychic Barrier" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="7872-87d1-fc12-a4f9">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Until the next time this unit is Activated or dies, after a model in this unit suffers a wound, roll a D6. On a 5+, that attack fails.</characteristic>
          </characteristics>
        </profile>
        <profile name="3 Horrible Presence" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="2cd1-1d27-36a6-906c">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Each enemy unit within 16” and visible to this unit suffers D3+1 Suppression.</characteristic>
          </characteristics>
        </profile>
        <profile name="4 Psychic Scream" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="9a3f-c56d-b386-b1fe">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Each enemy unit within 8” of this unit suffers D3+2 Suppression.</characteristic>
          </characteristics>
        </profile>
        <profile name="5 Manifest Hate" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="c811-4d37-d1e3-e1fc">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select an enemy unit with 16” and visible to this unit. That unit suffers 4+2D3 SW.</characteristic>
          </characteristics>
        </profile>
        <profile name="6 Metabolic Catalyst" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="6a0a-3c91-fd32-0a07">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select a friendly infantry unit within 12” of this unit. Until the next time this unit is Activated or dies, that unit gains:

Dominated Metabolism: Each time a model in this unit dies, do not remove it from the battlefield until the end of the battle round. Those models cannot be selected to suffer wounds, and may move and attack as if they were still alive.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Relics (Reference)" hidden="false" id="bb6e-73eb-2dfd-0da4" sortIndex="-5">
      <constraints>
        <constraint type="max" value="1" field="selections" scope="force" shared="true" id="bcaa-5e43-09fb-24cc" includeChildSelections="false"/>
        <constraint type="min" value="1" field="selections" scope="force" shared="true" id="c50e-c4e3-bd73-2471" includeChildSelections="false"/>
        <constraint type="max" value="1" field="selections" scope="force" shared="true" id="fe4e-78ca-5473-c0a3" includeChildSelections="false"/>
      </constraints>
      <categoryLinks>
        <categoryLink name="Configuration" hidden="false" id="e578-ea6e-6ade-589f" targetId="9cd6-0442-3f35-6b52" primary="true"/>
      </categoryLinks>
      <profiles>
        <profile name="1 Resonance Barb" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="507b-19cc-40d2-3ec9">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit makes a Psychic Test, this unit Heals X where X is equal to the highest roll in that Psychic Test.</characteristic>
          </characteristics>
        </profile>
        <profile name="2 Dirgeheart of Kharis" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="34e4-0cf8-f9a9-7b88">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit’s Move step, each enemy unit within X” where X is this unit’s Toughness suffers D3+1 Suppression.</characteristic>
          </characteristics>
        </profile>
        <profile name="3 Rapid Evolution" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="33e4-356c-d28f-aaef">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit gains this ability, select one adaptation ability. While this unit has this ability, it has the selected ability, even if it has another ability with the same name.</characteristic>
          </characteristics>
        </profile>
        <profile name="4 Evolutionary Leap" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="eba0-9c4b-a0ec-5e77">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit gains this ability, select one adaptation ability. While this unit has this ability, it has the selected ability, even if it has another ability with the same name.</characteristic>
          </characteristics>
        </profile>
        <profile name="6 Repurposed Bioforms" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="9909-3ae2-1996-8f7c">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After a unit gains this ability, you may Deploy one of your destroyed units with Adaptive Bioform wholly within your deployment zone with full Health and ready. This ability may only be used once per battle, even if another unit gains it.</characteristic>
          </characteristics>
        </profile>
        <profile name="5 Perfect Adaptation" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="6d05-f68a-0bb0-c046">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit gains this ability, select one adaptation ability. While this unit has this ability, it has the selected ability, even if it has another ability with the same name.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
