      </categoryLinks>
      <profiles>
        <profile name="1 Khorne’s Scarification" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="eb82-3099-ed7f-ae48">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">This unit&apos;s T is improved to 8.</characteristic>
          </characteristics>
        </profile>
        <profile name="2 Adrenalizing Nails" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="5e50-3904-bf31-b5a7">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">For each Move Roll made for this unit, add 8 to that Move Roll.</characteristic>
          </characteristics>
        </profile>
        <profile name="4 Angron’s Doctrine" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="8c2a-5d04-a6be-951d">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">For each melee attack this unit makes, reroll a Hit Roll of 1 for that attack. After this unit’s End step, if this was not your second turn in a row, you may take another turn. If you do, for each attack your active unit makes during that turn, reroll a failed Hit Roll for that attack.</characteristic>
          </characteristics>
        </profile>
        <profile name="6 Skulls for the Skull Throne!" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="eaf3-34ab-0b99-41f3">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">While enemy units are within 16” of this unit, those enemy units count as one additional enemy unit for Martial Savagery.</characteristic>
          </characteristics>
        </profile>
        <profile name="5 Blood for the Blood God!" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="40a7-893d-437b-a5d3">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">For each melee attack this unit makes, a Wound Roll of 5+ for that attack causes an additional wound.</characteristic>
          </characteristics>
        </profile>
        <profile name="3 Berserker’s Visage" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="7134-9af4-eea7-c2da">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">For each melee attack this unit makes, reroll a Wound Roll of 1 for that attack. After this units&apos; Attack step, each enemy unit within 8” suffers X Suppression where X is equal to the Health lost this turn.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
