            <characteristic name="S" typeId="571c-0471-2614-c57c">7</characteristic>
            <characteristic name="D" typeId="c2c0-3714-05e2-65a0">2</characteristic>
            <characteristic name="Abilities" typeId="d93f-70ee-72bc-5ef9">For each attack made for this weapon targeting an infantry or monster, add 1 to the Wound Roll of that attack.</characteristic>
          </characteristics>
        </profile>
