      <categoryLinks>
        <categoryLink name="Configuration" hidden="false" id="7cf5-b5de-ce48-ea2d" targetId="9cd6-0442-3f35-6b52" primary="true"/>
      </categoryLinks>
      <profiles>
        <profile name="1 Shared Vision Lens" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="48fc-ce52-0489-d5f9">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit’s End step, if this turn was not your second turn in a row, you may take another turn. If you do, during that turn, for each Hit Roll made by the unit you Activate, reroll a failed Hit Roll for that attack.</characteristic>
          </characteristics>
        </profile>
        <profile name="2 Orbital Rangefinder" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="015e-ecf0-0464-a5aa">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">Each time this unit selects a target for a ranged weapon, you may select an enemy unit with Marked an additional 4” away.</characteristic>
          </characteristics>
        </profile>
        <profile name="4 Drone Distributor" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="ebd1-9305-59c9-c256">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After a unit gains this ability, add 2 SHIELD DRONE models to this unit and it gains Shield Drone.</characteristic>
          </characteristics>
        </profile>
        <profile name="6 Puretide Engram Chip" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="de81-8cd3-57af-3c6d">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">For each ranged attack made by this unit that targets an enemy unit with Marked, Hit Rolls of 5+ cause an additional hit.</characteristic>
          </characteristics>
        </profile>
        <profile name="5 Targeting Telemetry" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="6083-786b-5732-910a">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">For each ranged attack made by this unit that targets an enemy unit with Marked, reroll a fail Hit Roll for that attack.</characteristic>
          </characteristics>
        </profile>
        <profile name="3 Counterfire Defence System" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="d78f-5874-cfd2-d6ad">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After the Move step while an enemy unit is active and visible to this unit, you may roll a D6. On a 5+, this unit makes ranged attacks targeting that enemy unit (if able).</characteristic>
          </characteristics>
        </profile>
      </profiles>
