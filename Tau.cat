        <constraint type="min" value="1" field="selections" scope="force" shared="true" id="4d40-0743-5cd4-2807" includeChildSelections="false"/>
        <constraint type="max" value="1" field="selections" scope="force" shared="true" id="b240-bfb8-a7e4-5028" includeChildSelections="false"/>
