  <sharedRules>
    <rule name="Nemesis" id="24b5-5baa-5c44-0c42" hidden="false">
      <description>For each of this weapon’s attacks, a Wound Roll of 6 for that attack causes the target unit to suffer X SW where X is equal to that weapon&apos;s damage. If the target unit has Daemonic, those SW gain Pierce.</description>
    </rule>
  </sharedRules>
