        <profile typeId="55da-e0a0-1fa3-2d1c" typeName="Leader" hidden="false" id="599d-e4c9-a28c-7958">
          <characteristics>
            <characteristic name="Must Attach to" typeId="2c63-5e3f-9132-459d">This unit cannot attach to anything.</characteristic>
          </characteristics>
        </profile>
        <profile name="Regimental Orders" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="9e7d-b04e-f116-3483">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After you Activate another Astra Militarum vehicle within 24”, that unit may gain one of the following abilities. If it already has one of these abilities, select one of those abilities and it loses the other:


Pin Them Down: Each of this unit’s ranged weapons gains Suppressive X where X is equal to the D of that weapon. For each ranged attack this unit makes, the Hit Roll for that attack is worsened by 1. After the End step, this unit loses this ability.


Grinding Treads: After this unit’s Move step, you may select an enemy unit within the engagement range of this unit. The select unit suffers SW equal to this unit’s Toughness.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <selectionEntries>
        <selectionEntry type="model" import="true" name="Tank Commander" hidden="false" id="de87-7769-8418-b393">
          <constraints>
            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="7ac0-d90e-6bcd-d473-min" includeChildSelections="false"/>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="7ac0-d90e-6bcd-d473-max" includeChildSelections="false"/>
          </constraints>
          <entryLinks>
            <entryLink import="true" name="Dozer Blade" hidden="false" id="ce9f-4310-d9c0-d542" type="selectionEntry" targetId="272c-60ae-6f13-26dc"/>
