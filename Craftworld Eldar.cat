<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<catalogue library="false" id="14ba-fba9-02a2-388d" name="Craftworld Eldar" gameSystemId="sys-c49b-9f87-36f1-c9b5" gameSystemRevision="6" revision="15" battleScribeVersion="2.03" type="catalogue" xmlns="http://www.battlescribe.net/schema/catalogueSchema">
  <sharedRules>
    <rule name="Foretold Foray" id="d0c2-99f6-070a-f4ed" hidden="false">
      <description>After rolling for initiative battle round 1, roll Strands of Fate X where X is twice the number of leader units you have on the battlefield and reserves.</description>
    </rule>
    <rule name="Roaming Performers" id="c56f-e048-3acd-ec3d" hidden="false">
      <description>You may also add any of the following Harlequins units to your Army List:


a) TROUPE MASTER
b) SHADOWSEER
and up to three:
c) TROUPE


Each of those units gains a different Masque&apos;s Ensemble ability from either Light, Dark or Twilight. If you do add one or more of those units to your Army List, your Army Rules gains Prismatic Pirouette, Kaleidoscopic Cavalcade and Mocking Misstep.</description>
    </rule>
    <rule name=" Aspect (X)" id="9db0-7796-725a-f91f" hidden="false">
      <description>While this unit is ready, after each of your End steps, if this was not your second turn in a row, you may take another turn. If you do, you must select a unit with Aspect Warrior to activate that turn.</description>
    </rule>
    <rule name="Eyes of the Asuryani" id="3be3-6578-1b0d-7468" hidden="false">
      <description>While this unit is not active, enemy units visible to this unit gain the following ability:

Fatal Thread: For each attack made by an Aeldari Craftworlds unit that targets this unit, a Hit Roll of 6 always wounds.</description>
    </rule>
  </sharedRules>
