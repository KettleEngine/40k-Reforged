    <selectionEntry type="upgrade" import="true" name="Relics (Refrence)" hidden="false" id="d9bc-82df-cc4c-d692" sortIndex="3">
      <categoryLinks>
        <categoryLink name="Configuration" hidden="false" id="8aa5-aa14-8e03-1784" targetId="9cd6-0442-3f35-6b52" primary="true"/>
