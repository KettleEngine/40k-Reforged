          </characteristics>
        </profile>
        <profile name="Tank Commander" typeId="a706-96eb-fcae-b696" typeName="Unit" hidden="false" id="8d9e-6aab-c036-1d79">
          <characteristics>
            <characteristic name="M" typeId="c06e-b1a2-0f87-fe2f">6&quot;</characteristic>
            <characteristic name="T" typeId="a6ad-d820-8495-f5b0">9</characteristic>
            <characteristic name="Sv" typeId="9b7f-0dde-683f-6844">4+</characteristic>
            <characteristic name="H" typeId="18e4-1bf9-a9b8-1e50">13</characteristic>
            <characteristic name="Rv" typeId="411f-3942-6dc0-7c06">5+</characteristic>
          </characteristics>
        </profile>
        <profile name="Regimental Orders" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="9e7d-b04e-f116-3483">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After you Activate another Astra Militarum vehicle within 24”, that unit may gain one of the following abilities. If it already has one of these abilities, select one of those abilities and it loses the other:


Pin Them Down: Each of this unit’s ranged weapons gains Suppressive X where X is equal to the D of that weapon. For each ranged attack this unit makes, the Hit Roll for that attack is worsened by 1. After the End step, this unit loses this ability.


Grinding Treads: After this unit’s Move step, you may select an enemy unit within the engagement range of this unit. The select unit suffers SW equal to this unit’s Toughness.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <selectionEntryGroups>
        <selectionEntryGroup name="For an additional 30 points, this model may also be equipped with either" id="f6f3-76fe-5919-4c11" hidden="false">
          <entryLinks>
            <entryLink import="true" name="Heavy Bolter" hidden="false" id="80c7-a104-8d2d-60af" type="selectionEntry" targetId="82a1-b562-e748-d5ad">
              <costs>
                <cost name="pts" typeId="points" value="30"/>
              </costs>
              <modifiers>
                <modifier type="set" value="10" field="13c5-f234-c120-afc3" affects="profiles.Weapon"/>
                <modifier type="set" value="4+" field="459f-6890-e77f-b62f" affects="profiles.Weapon"/>
                <modifier type="prepend" value="Sponson" field="name" affects="profiles.Weapon"/>
              </modifiers>
            </entryLink>
