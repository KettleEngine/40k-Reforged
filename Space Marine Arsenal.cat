            </modifier>
          </modifiers>
          <comment>Space Wolves</comment>
        </profile>
        <profile name="6 Gjallarhorn of the Alfather" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="true" id="0743-7019-205b-3db1">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit Activates, select up to one of your ready units within 8” of this unit. Each model in this unit and the selected unit gains the weapon below until the End step of the next turn. Then, if you selected another unit, after this turn’s End step, take another turn, and you must select that unit to Activate that turn.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="6e28-72e3-f8fe-a6d3" shared="true" includeChildSelections="true" childName="Space Wolves"/>
