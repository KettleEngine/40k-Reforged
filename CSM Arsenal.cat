    <selectionEntryGroup name="Chaos Disciple" id="ff07-25ed-c9db-0945" hidden="false" defaultSelectionEntryId="e351-8cb4-3322-b80b">
      <selectionEntries>
        <selectionEntry type="upgrade" import="true" name="Disciple of Nurgle" hidden="false" id="f416-1e6c-eb17-4a97" sortIndex="2">
          <profiles>
            <profile name="1 Shriveling Pox" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="5adc-374e-13e4-4929">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select an enemy unit within 14” of this unit. Until the End step, the selected unit’s Toughness is worsened by 3. If the selected unit is within 7”, its Toughness is worsened by 7 instead.</characteristic>
              </characteristics>
            </profile>
            <profile name="2 Dance for the Grandfather" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="29cc-a3c6-0832-f044">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select an enemy infantry or monster unit within 16” of and visible to this unit. Until the End step, for each attack that targets that unit this turn, reroll a failed Hit Roll for that attack.</characteristic>
              </characteristics>
            </profile>
            <profile name="3 Pestilent Miasma" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="7dbf-8fd2-b9b8-1ff4">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Until the next time this unit is Activated or dies, for each Move Roll made for an enemy unit while that unit is within 14” of this unit, they must discard the highest result of the 2 D6.</characteristic>
              </characteristics>
            </profile>
            <profile name="4 Aura of Decay" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="59d8-4c23-536b-eb91">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Until the next time this unit is Activated or dies, after an enemy unit is Activated within 7” of this unit, that unit suffers 3D3 Suppression.</characteristic>
              </characteristics>
            </profile>
            <profile name="5 Fleshy Abundance" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="ec48-8bed-5e7d-6a36">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select a friendly unit within 14” of this unit. Until the nnext time this unit is Activated or dies, the selected unit gains Resilient 6+ and the following ability:


Grotesquely Resilient: Add 1 to Resilient rolls made for this unit</characteristic>
              </characteristics>
            </profile>
            <profile name="6 Rancid Visitations" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="1480-9066-a62c-28f8">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select an enemy unit with 14” and visible to this unit. The selected unit suffers D3+7 Suppression. If the selected unit is within 7”, it suffers 2D3+7 Suppression instead.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink name="Resilient (X)" id="ac9b-00b2-481c-bbaf" hidden="false" type="rule" targetId="253c-c1fa-d29d-d21e"/>
            <infoLink name="Suppressive (X)" id="5020-cd26-4dfc-6dc8" hidden="false" type="rule" targetId="aed3-e154-8fa2-5378"/>
          </infoLinks>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Disciple of Slaanesh" hidden="false" id="ed37-5f6a-c35d-ccce" sortIndex="3">
          <profiles>
            <profile name="1 Cacophonic Choir" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="3721-f0e3-3c3f-49a4">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Until the End step, for each Resolve Test made for benemy units within 6” of this unit, a result of 6 always fails. Then, each nenemy unit within 6” suffers D3+2 Suppression.</characteristic>
              </characteristics>
            </profile>
            <profile name="2 Siren" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="4aa6-419c-4383-7e95">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Until the next time this unit is Activated or dies, for each attack that targets this unit, the Hit Roll of that attack is worsened by 1.</characteristic>
              </characteristics>
            </profile>
            <profile name="3 Phantasmagoria" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="3574-e8c8-648f-9b09">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select an enemy infantry unit within 16” of and visible to this unit. The selected unit suffers 3D3 Suppression. Then, that unit suffers X SW where X is equal to its Suppressed X.</characteristic>
              </characteristics>
            </profile>
            <profile name="4 Blissful Devotion" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="f0ee-54c9-3880-6eda">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select a friendly infantry unit within 12” of this unit. This unit and the selected unit may Reposition up to 6”.</characteristic>
              </characteristics>
            </profile>
            <profile name="5 Symphony of Pain" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="74e4-3a53-1b48-a522">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select an enemy unit within 12”. The selected enemy unit suffers 3+2D3 SW. If that enemy unit is within 6”, it suffers 5+2D3 SW instead.</characteristic>
              </characteristics>
            </profile>
            <profile name="6 Touch of Slaanesh" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="4300-5871-41b8-b290">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Until the End step, for each attack made by this unit, a Saving Throw of 6 always fails for that attack.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink name="Suppressive (X)" id="4558-1a50-ba7b-5a86" hidden="false" type="rule" targetId="aed3-e154-8fa2-5378"/>
          </infoLinks>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Disciple of Tzeentch" hidden="false" id="623c-435e-4705-c5b6" sortIndex="1">
          <profiles>
            <profile name="1 Temporal Surge" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="5269-c330-6472-7c2c">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select a friendly unit within 18” of and visible to this unit. Until the end of the battle round, the selected unit&apos;s Move Rolls are improved by 9”.</characteristic>
              </characteristics>
            </profile>
            <profile name="2 Twist Fate" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="d692-3898-67af-f493">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Until the End step, for each attack this unit makes, a Hit Roll of 2 for that attack is always successful.</characteristic>
              </characteristics>
            </profile>
            <profile name="3 Boon of Mutation" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="0b1a-76fb-5a82-998d">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select a single model in a friendly unit within 9” of and visible to this unit. That selected model’s Health is improved by 2 (you may use a Health counter or dice to track it)</characteristic>
              </characteristics>
            </profile>
            <profile name="4 Switch Reality" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="18ed-4cf9-97ca-e204">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select a visible friendly unit. Place a marker within 1” of this unit and the selected unit. Then, remove both units from the battlefield and place them into reserves. Then, Deploy both units onto the battlefield wholly within 6” of the other unit&apos;s marker</characteristic>
              </characteristics>
            </profile>
            <profile name="5 Withering Gaze" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="3727-1908-bcb8-2bf3">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select a visible enemy unit with 16”. The selected enemy unit suffers 3D6 Suppression.</characteristic>
              </characteristics>
            </profile>
            <profile name="6 Desecration of Worlds" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="6b19-076d-bfe1-d6fa">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select two points along the battlefield edge. Each different enemy unit along the line between those two points suffers 2 SW.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink name="Suppressive (X)" id="e431-5691-a07f-89d3" hidden="false" type="rule" targetId="aed3-e154-8fa2-5378"/>
          </infoLinks>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Undivided" hidden="false" id="e351-8cb4-3322-b80b" sortIndex="4">
          <profiles>
            <profile name="1 Daemonshriek" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="5c07-5228-3000-8a9d">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Each enemy unit within 16” of this unit suffers D3+1 Suppression. Then, until the next time this unit is Activated or dies, while any enemy unit on the battlefield has Suppressed, those units gain Dark Gods’ Hatred.</characteristic>
              </characteristics>
            </profile>
            <profile name="2 Diabolic Strength" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="8318-1fc6-e13d-a757">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Until the next time this unit is Activated or dies, for each melee attack this unit makes, reroll a failed Wound Roll for that attack.</characteristic>
              </characteristics>
            </profile>
            <profile name="3 Lay Leach" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="1d9b-1a06-df53-4c8f">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select a friendly infantry unit within 16” of this unit. The selected unit Heals 2. If the selected unit is a chaos unit, the unit Heals D3+1 instead.</characteristic>
              </characteristics>
            </profile>
            <profile name="4 Empyric Shield" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="0573-483d-eb35-eadb">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Until the next time this unit is Activated or dies, after a model in this unit suffers a wound from a ranged attack, roll a D6. On a 5+, that attack fails.</characteristic>
              </characteristics>
            </profile>
            <profile name="5 Doombolt" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="82a9-2b7a-a07e-47aa">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select an enemy unit visible to and within 16” of this unit. The selected enemy unit suffers 4+2D3 SW.</characteristic>
              </characteristics>
            </profile>
            <profile name="6 Dark Blessings" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="2116-871b-51e9-895c">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">This unit loses D3+1 Health. Then, each enemy unit within 12” suffers 3D3+X SW where X is the amount of Health this unit lost.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink name="Heal/Repair (X)" id="d933-803f-bf5d-6595" hidden="false" type="rule" targetId="02c8-1ec5-cdab-2572"/>
            <infoLink name="Dark Gods’ Hatred" id="d347-6445-4144-97a3" hidden="false" type="profile" targetId="757c-1e05-d2fb-d633"/>
            <infoLink name="Suppressive (X)" id="c097-5116-327d-e2c2" hidden="false" type="rule" targetId="aed3-e154-8fa2-5378"/>
          </infoLinks>
        </selectionEntry>
      </selectionEntries>
      <constraints>
        <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="516b-2d85-ce9f-2ffd-min" includeChildSelections="false"/>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="516b-2d85-ce9f-2ffd-max" includeChildSelections="false"/>
      </constraints>
    </selectionEntryGroup>
  </sharedSelectionEntryGroups>
</catalogue>
