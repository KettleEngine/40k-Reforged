              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select an enemy unit with 16” of and visible to this unit. The selected unit suffers 3D6 SW.</characteristic>
              </characteristics>
            </profile>
            <profile name="3 Psyker Barrier" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="356b-0645-7e85-e745">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Until the next time this unit Activates or dies, its Sv unit’s Sv changes to 3+.</characteristic>
              </characteristics>
            </profile>
            <profile name="5 Psychic Maelstrom" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="510a-4c49-8e7b-9411">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select a visible point on the battlefield with 16” and select up to 4 enemy units within 6” of the selected point. Each selected unit suffers 2D3 SW.</characteristic>
              </characteristics>
            </profile>
            <profile name="4 Mental Fortitude" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="cf24-13de-5994-9f20">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Until the next time this unit is Activated or dies, this unit’s Rv changes to 4+ and for each SW that targets this unit, the Sv of this unit changes to 4+ for that attack.</characteristic>
              </characteristics>
            </profile>
          </profiles>
        </selectionEntry>
