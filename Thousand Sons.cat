        <profile name="Seize the Moment" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="726a-813b-7cb7-f405">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">While this unit is ready, after each of your End steps, if this was not your second turn in a row, you may take another turn and you must select this unit to activate that turn.</characteristic>
          </characteristics>
        </profile>
        <profile name="Chronal Shift" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="9c4d-462e-7d2e-b234">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">While this unit is on the battlefield, when you roll for initiative, if this unit is within 9” of another with Entwined Will, you may add 1 D6 to that initiative roll.</characteristic>
          </characteristics>
        </profile>
