        <selectionEntry type="upgrade" import="true" name="Malefic Discipline" hidden="false" id="53a1-e879-d795-5026">
          <constraints>
            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="3995-9f00-6cff-00bd-min" includeChildSelections="false"/>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="3995-9f00-6cff-00bd-max" includeChildSelections="false"/>
          </constraints>
          <profiles>
            <profile name="1 Pact of Flesh" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="3f68-6860-2930-1da2">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select a friendly infantry unit within 6”. If the selected unit is a POSSESSED unit, add 1 POSSESSED model to that unit. Otherwise, it Heals D3+1 instead.</characteristic>
              </characteristics>
            </profile>
            <profile name="2 Cursed Earth" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="d494-f47c-1641-d325">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select a point on the battlefield within 24” of this unit and mark it. Until the end of the battle round, enemy units within 16” of the selected point gain Dark Gods’ Hatred.</characteristic>
              </characteristics>
            </profile>
            <profile name="3 Infernal Power" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="feee-22ec-1f3c-7b9c">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Until the next time this unit Activates or dies, while your units with Daemonic are within 16” of this unit, those units gain the following ability:


Daemonic Strength: For each attack made for this unit, a Wound Roll of 6 for that attack causes an additional wound.</characteristic>
              </characteristics>
            </profile>
            <profile name="4 Sacrifice" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="e9e8-a609-2de4-58be">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select a friendly infantry unit within 12”. The selected unit loses D3+1 Health. Then, select a different friendly infantry within 12” of this unit. That selected unit Heals X, where X is equal to the result of that roll. If that unit has Daemonic, it Heals X+D3 instead.</characteristic>
              </characteristics>
            </profile>
            <profile name="5 Agonizing Ritual" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="79f1-2185-5ae1-1939">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select an infantry model with 2 or more Health remaining from one of your units within 12” of this unit. The selected model dies. Then, if there are any friendly POSSESSED units on the battlefield, add 1 POSSESSED model to one of those units. Otherwise, create a ready POSSESSED unit within 1” of this unit with 1 model.</characteristic>
              </characteristics>
            </profile>
            <profile name="6 Mutating Possession" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="9fb1-5bc3-870a-538a">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select an enemy unit with Dark Gods’ Hatred, visible to and within 16” of this unit. The selected enemy unit suffers 2D3+1 SW. Then, if one or more models died as a result of those SW, create a ready POSSESSED unit with 1 model within 2” and outside of the engagement range of that enemy unit.</characteristic>
              </characteristics>
            </profile>
          </profiles>
        </selectionEntry>
      </selectionEntries>
      <infoLinks>
