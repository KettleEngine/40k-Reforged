        <profile name="4 Living Lighting" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="true" id="9d17-6055-cc4c-1edd">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select an enemy unit within 12” of and visible to this unit. Then select another enemy unit within 12” of and visible to the first unit. Each selected unit suffers 2+D3 SW.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
