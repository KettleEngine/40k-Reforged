          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">While this unit is the closest of your units to the active enemy unit, add 1 to Resilient Rolls for this unit.</characteristic>
          </characteristics>
        </profile>
        <profile name="Great Butchery" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="91c6-4cce-ff7a-8e09">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">While this unit is within engagement range of any enemy unit and none of your other units are within 4” of this unit, for each attack made for this unit’s Eviscerator weapons, a Hit Roll of 5+ for that attack causes an additional hit.</characteristic>
          </characteristics>
        </profile>
