          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">For each Act of Faith roll this unit makes, roll an additional D6 and discard the lowest result of that roll.</characteristic>
          </characteristics>
        </profile>
        <profile name="Sisters’ Song" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="8746-2ef5-762d-cd5b">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">For each ranged attack that targets this unit, this unit gains Resilient 6+ for that attack.</characteristic>
          </characteristics>
        </profile>
        <profile name="Novitiate Hospitaller" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="263b-d021-9bf9-0514">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After this unit’s Move step, it Heals D3.</characteristic>
          </characteristics>
        </profile>
        <profile name="Eager for Glory" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="86a6-d106-454a-d09a">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">For each Move Roll made for this unit, add X D6 and drop the lowest X results where X is equal to the number of your other infantry units on the battlefield or in reserves.</characteristic>
          </characteristics>
        </profile>
