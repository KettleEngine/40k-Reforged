  <sharedProfiles>
    <profile name="Festering Advance" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="944e-46dd-e901-73d1">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">For each Advance Roll made for your units, roll 3D3 instead of 2D6. Additionally, during a March, your Death Guard units may move up to an additional 3” if that move would end within 4” of any enemy units with Nurgle’s Fruit.</characteristic>
      </characteristics>
    </profile>
    <profile name="Nurgle’s Gifts" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="1d15-546a-3644-21db">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After an enemy unit Activates within 7” of this unit, it suffers D3+1 Suppression.</characteristic>
      </characteristics>
    </profile>
    <profile name="Nurgle’s Fruit" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="2bc0-64a5-bf4e-b19c">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">For each attack made for a weapon with Plague or Putrid targeting this unit, reroll Wound Rolls of 1 for that attack.</characteristic>
      </characteristics>
    </profile>
    <profile name="Plaguebringers" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="1678-14a0-a939-cba2">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">While enemy units are within 14” of this unit, those units gain:


Nurgle’s Fruit: For each attack made for a weapon with Plague or Putrid targeting this unit, reroll Wound Rolls of 1 for that attack.</characteristic>
      </characteristics>
    </profile>
  </sharedProfiles>
  <sharedRules>
    <rule name="Plague" id="7985-d278-b6c4-f53e" hidden="false">
      <description>This weapon has Suppressive X where X is equal to this weapon’s Damage.</description>
    </rule>
    <rule name="Putrid" id="5262-b1f5-26c7-19b6" hidden="false">
      <description>For each attack made by this weapon, add 1 to the Wound Roll of that attack. Additionally, if the target of that attack has Nurgle’s Fruit, a Wound Roll of 6 causes an additional wound.</description>
    </rule>
  </sharedRules>
