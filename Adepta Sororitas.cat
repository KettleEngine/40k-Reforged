      <profiles>
        <profile name="Processional Shieldwall" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="102a-1fd0-3e3f-a32d">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After a ranged attack successfully wounds a friendly leader unit within 6” of this unit, while this unit is visible to and closer to the enemy unit that made that attack, you may roll a D6. On a 4+, that attack’s target changes to this unit.</characteristic>
          </characteristics>
        </profile>
      </profiles>
