            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">For each ranged attack that targets this unit, add 1 to the Saving Throw of that attack. After this unit advances or Disembarks, it loses this ability until the next time it&apos;s Activated.</characteristic>
          </characteristics>
        </profile>
        <profile name="In life, War" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="1ea2-ac75-69d0-2c41">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">For each ranged attack made by another friendly Astra Militarum unit that targets an enemy unit visible to this unit, reroll a Hit Roll of 1 for that attack.</characteristic>
          </characteristics>
        </profile>
