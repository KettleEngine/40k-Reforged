  <sharedProfiles>
    <profile name="Tech-Priest" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="d505-4156-df21-9043">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">Once per turn, after any of your units, Activate or finish their Move step, while within 8” of one or more units with Tech Priest, that unit Repairs 1.</characteristic>
      </characteristics>
    </profile>
    <profile name="Manufactorum Imperium" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="37fa-7d9c-6c8c-e33c">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">You may add vehicle units to your army list from the documents “40k Reforged: Astra Militarum” and “40k Reforged: Space Marine Arsenal”.</characteristic>
      </characteristics>
    </profile>
    <profile name="Invocate Machine" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="f914-73c8-f087-eadf">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After this unit’s End step, if this was not your second turn in a row, you must take another turn.</characteristic>
      </characteristics>
    </profile>
    <profile name="Omnissiah’s Blessing" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="2345-8a1c-18ba-8c53">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After any of your units Repair, until the End step, for each attack made by that unit, reroll Hit Rolls of 1 for that attack.</characteristic>
      </characteristics>
    </profile>
    <profile name="Predictive Algorithms" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="88fc-182e-a840-2df9">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">While this unit is within 1” of one of your other units, for each attack that targets this unit, add 1 to the Saving Throw of that attack.</characteristic>
      </characteristics>
    </profile>
    <profile name="Soothing Communion" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="c6e9-0484-509a-7b8d">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">For each Explode Roll made for one of your vehicle units within 9” of this unit, you may reroll that Explode Roll.</characteristic>
      </characteristics>
    </profile>
    <profile name="Radioactive" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="7d55-9f74-29f2-c388">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">For each melee attack that targets this unit, worsen the Wound Roll of that attack by 1. Additionally, while enemy infantry units are within 14” of this unit, those units gain the following ability:


Acute Rad-poisoning: For each Advance Roll made for this unit, roll 1 less D6 for that roll.</characteristic>
      </characteristics>
    </profile>
  </sharedProfiles>
  <sharedRules>
    <rule name="Radiation" id="89da-6037-0bd7-640b" hidden="false">
      <description>For each attack made for this weapon, if the target unit is an infantry or monster, add 1 to the Wound Roll of that attack.</description>
    </rule>
    <rule name="Arc" id="8120-0b96-92c6-b997" hidden="false">
      <description>For each attack made for this weapon, if the target unit is a vehicle, add 1 to the Wound Roll of that attack.</description>
    </rule>
  </sharedRules>
