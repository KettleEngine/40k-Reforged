      <profiles>
        <profile name="Storm of Retribution" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="148e-27df-0ebd-39ba">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">For each attack made for this unit which targets an enemy unit within 16” of another friendly infantry unit, a Hit Roll of 6 for that attack automatically wounds.</characteristic>
          </characteristics>
        </profile>
      </profiles>
