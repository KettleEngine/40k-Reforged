  <sharedProfiles>
    <profile name="Selfish Ascension" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="298d-635e-7f54-b527">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">Each time an enemy unit with Dark Gods’ Hatred dies, if the active unit is one of your Chaos Space Marines units, instead of ‘that unit Heals D3’, you may select one of your units with Selfish Ascension and improve the H of a Leader model in that unit by 1.</characteristic>
      </characteristics>
    </profile>
    <profile name="Traitorous Contempt" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="3941-84ed-06f0-8bcb">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">Enemy units within 16” of this unit gain the following ability:

Dark Gods’ Hatred: After this unit dies, if the active unit is a Chaos Space Marines unit, that unit Heals D3.</characteristic>
      </characteristics>
    </profile>
    <profile name="Dark Gods’ Hatred" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="757c-1e05-d2fb-d633">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After this unit dies, if the active unit is a Chaos Space Marines unit, that unit Heals D3.</characteristic>
      </characteristics>
    </profile>
    <profile name="Rupture" typeId="266a-be4d-b9fa-94de" typeName="Windfall of the Warp" hidden="false" id="b860-055d-17c3-2fa6">
      <characteristics>
        <characteristic name="Psychic Power" typeId="9060-973c-99e9-75b4">After this unit makes a Psychic Test, if that Psychic Test had two or more dice with the same result, select a visible point on the battlefield with 24” and mark it. Each enemy unit within 1” of the centre of that point suffers 3D3 SW.</characteristic>
      </characteristics>
    </profile>
    <profile name="Mutated Invigoration" typeId="266a-be4d-b9fa-94de" typeName="Windfall of the Warp" hidden="false" id="851b-d3b5-a483-5134">
      <characteristics>
        <characteristic name="Psychic Power" typeId="9060-973c-99e9-75b4">Select a friendly infantry unit within 12”. The selected unit Heals D3. If that unit has one or more models with Daemonic, it Heals D3+1 instead.</characteristic>
      </characteristics>
    </profile>
  </sharedProfiles>
  <sharedSelectionEntries>
    <selectionEntry type="upgrade" import="true" name="Champion of Chaos" hidden="false" id="d39b-d0f0-66db-fe7f">
      <constraints>
        <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="ddfb-4149-1042-ba1d-min" includeChildSelections="false"/>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="ddfb-4149-1042-ba1d-max" includeChildSelections="false"/>
      </constraints>
      <profiles>
        <profile name="The Long War" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="true" id="7c2b-9a38-732a-9d20">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After rolling for initiative during battle round 1, select one enemy unit. That enemy unit gains Abaddon’s Contempt. After rolling for initiative during battle round 2, select a vault at random. Then, after any battle round, if you have two or more units within 4” of that vault, all enemy units gain Abaddon&apos;s Contempt for the rest of the battle.

Abaddon&apos;s Contempt: For each attack made by a Chaos Space Marines unit that targets this unit, a Hit Roll of 6 for that attack causes an additional hit.</characteristic>
          </characteristics>
          <comment>Black Legion</comment>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="4664-cd3f-b95b-a458" shared="true" includeChildSelections="true" childName="Black Legion"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="Misinformation Architect" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="true" id="9958-5bf0-24a4-eeaa">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">Once per battle round, after an enemy unit is Activated, you may select one of your ready units within 24” of this unit. Remove the selected unit from the battlefield and place it into reserves.</characteristic>
          </characteristics>
          <comment>Alpha Legion</comment>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="d592-5a78-0580-1d03" shared="true" includeChildSelections="true" childName="Alpha Legion"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="Iron Cage Doctrine" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="true" id="efbe-63af-d868-6205">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After this unit’s Move step, you may select a point on the battlefield within 16” of this unit and mark it. Until the next time this unit is Activated or dies, for each attack made by any of your unit’s models which targets an enemy unit within 16” of the centre of that point, reroll a Hit Roll of 1 for that attack.</characteristic>
          </characteristics>
          <comment>Iron Warriors</comment>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="27b0-cf36-cd17-73c6" shared="true" includeChildSelections="true" childName="Iron Warriors"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="Iron Within" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="true" id="2be0-93a5-e801-5d38">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After any of your units with Suppressed X Activate within 16&quot; of this unit, reduce X by 1.</characteristic>
          </characteristics>
          <comment>Iron Warriors</comment>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="27b0-cf36-cd17-73c6" shared="true" includeChildSelections="true" childName="Iron Warriors"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="Iron Without" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="true" id="41a7-a695-893f-4449">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">While your units are within 16&quot; of this unit, those units gain Resilient 6+</characteristic>
          </characteristics>
          <comment>Iron Warriors</comment>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="27b0-cf36-cd17-73c6" shared="true" includeChildSelections="true" childName="Iron Warriors"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="The Long War" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="true" id="66ed-9168-4359-79af">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After rolling for initiative during battle round 1, select one enemy unit. That enemy unit gains Abaddon’s Contempt. After rolling for initiative during battle round 2, select a vault at random. Then, after any battle round, if you have two or more units within 4” of that vault, all enemy units gain Abaddon&apos;s Contempt for the rest of the battle.

Abaddon&apos;s Contempt: For each attack made by a Chaos Space Marines unit that targets this unit, a Hit Roll of 6 for that attack causes an additional hit.</characteristic>
          </characteristics>
          <comment>Black Legion</comment>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="4664-cd3f-b95b-a458" shared="true" includeChildSelections="true" childName="Black Legion"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="Terror Tactics" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="true" id="8f95-fe43-cd0c-e0eb">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">While your units are within 24&quot; of this unit, those units gain the following abilities: 

We Bring The Night: After this unit is Activated, select an enemy unit not visible to this unit. Once this turn, after this unit finishes a Pile In within engagement range of that unit this turn, that unit suffers 3+2D3 Suppression.

Cruel Ambush: Each melee weapon equipped to models in this unit gains Isolate.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="1fa8-6666-7875-be1b" shared="true" includeChildSelections="true" childName="Night Lords"/>
              </conditions>
            </modifier>
          </modifiers>
          <comment>Night Lords</comment>
        </profile>
        <profile name="Abaddon&apos;s Contempt" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="true" id="60ce-184f-ea5d-ca84">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">For each attack made by a Chaos Space Marines unit that targets this unit, a Hit Roll of 6 for that attack causes an additional hit.</characteristic>
          </characteristics>
          <comment>Black Legion</comment>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="4664-cd3f-b95b-a458" shared="true" includeChildSelections="true" childName="Black Legion"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="Clandestine Deployment" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="true" id="50bc-66c8-0bdd-9edd">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After any of your units are Activated in reserves, you may Deploy that unit anywhere on the battlefield not visible to any enemy units, and not within 2D6+8” of the enemy deployment zone. That unit cannot Advance or Reposition this turn.</characteristic>
          </characteristics>
          <comment>Alpha Legion</comment>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="d592-5a78-0580-1d03" shared="true" includeChildSelections="true" childName="Alpha Legion"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="Multi-Headed Hydra" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="true" id="3427-67ac-8138-76c6">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After any of your leader units within 24” of this unit die, roll a D6. On a 4+, select another one of your models in the battlefield. That model’s unit gains the unit abilities on that leader’s unit profile and becomes a leader in addition to its other types.</characteristic>
          </characteristics>
          <comment>Alpha Legion</comment>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="d592-5a78-0580-1d03" shared="true" includeChildSelections="true" childName="Alpha Legion"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
      </profiles>
