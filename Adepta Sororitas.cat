            <characteristic name="Rv" typeId="411f-3942-6dc0-7c06">2+</characteristic>
          </characteristics>
        </profile>
        <profile name="Resurrection" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="b18f-ba63-7b31-d5af">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After this unit fails an Act of Faith roll, roll a D6. On a 6, place this unit into reserves with full Health.</characteristic>
          </characteristics>
        </profile>
        <profile name="Divine Intervention" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="e5d0-fa0b-d26f-b9b9">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After this unit is Activated in reserves, you may use ‘divine intervention’. If you do, roll 3D6. Then, you may Deploy this unit anywhere on the battlefield at least X” away from all enemy units where X is the result of that roll. If you do, this unit cannot March or Fall Back this turn.</characteristic>
          </characteristics>
        </profile>
        <profile name="Darkest Hour" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="ec86-1ff7-f570-ca94">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">While this unit is in reserves, after one of your units makes a successful Act of Faith roll, you may Deploy this unit within 4&quot; of that unit.</characteristic>
          </characteristics>
        </profile>
        <profile name="Inviolable Aura" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="626c-ff18-5a56-1417">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After this unit is Deployed, select up to 2 different friendly infantry units within 8&quot; of this unit. The selected units Heal D3.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <infoLinks>
