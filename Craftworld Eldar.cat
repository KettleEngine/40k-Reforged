    <selectionEntry type="upgrade" import="true" name="Psychic Powers (Reference)" hidden="false" id="cb57-8ddf-8547-48b1" sortIndex="-4">
      <profiles>
        <profile name="1. Song of Souls" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="5661-15c3-120e-477f">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select a friendly unit on the battlefield. The selected unit may Reposition. Then, the selected unit Heals 1. If that unit has Wraithbone, it Heals D3 instead.</characteristic>
          </characteristics>
        </profile>
        <profile name="2. Webway Leap" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="ac7f-83f6-9d25-2ea0">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select any of your infantry units in the battlefield. Remove that unit from the battlefield and place it into reserves. Then, Deploy wholly within 6&quot; of this unit, outside of the engagement range of enemy models.</characteristic>
          </characteristics>
        </profile>
        <profile name="3. Combinatorial Foresight" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="e5c9-9797-3640-40c2">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Until the next time this unit is Activated or dies, after a model in a friendly unit within 12” of and visible to this unit suffers a wound, roll a D6. On a 6, that attack fails.</characteristic>
          </characteristics>
        </profile>
        <profile name="4. Eldritch Bolt" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="4d29-91e4-ba19-e9ab">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select one unit within 16” of and visible to this unit. That unit suffers 4+2D3 SW.</characteristic>
          </characteristics>
        </profile>
        <profile name="5. Eldritch Storm" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="d24c-86a1-6524-c6a0">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select one point on the battlefield within 16&quot; of this unit. All units within 2D6” of that point each suffer 3 SW.</characteristic>
          </characteristics>
        </profile>
        <profile name="6. Battle Meditations" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="d934-e5eb-df8a-5194">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Until the next time this unit is Activated or dies, each time a model in a friendly unit within 12” of and visible to this unit makes a Move Roll, you may roll 6+D6 instead of 2D6.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink name="Configuration" hidden="false" id="cd84-103a-aa64-1bca" targetId="9cd6-0442-3f35-6b52" primary="true"/>
      </categoryLinks>
