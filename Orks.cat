        <profile name="Figh’y Joose" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="e6e4-f4fa-16d6-4460">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">Each time a model in this unit dies, do not remove it from the battlefield until the end of the battle round. Those models cannot be selected to suffer wounds, and may move and attack as if they were still alive.</characteristic>
          </characteristics>
        </profile>
        <profile typeId="55da-e0a0-1fa3-2d1c" typeName="Leader" hidden="false" id="7128-238e-f4fe-24b9">
          <characteristics>
            <characteristic name="Must Attach to" typeId="2c63-5e3f-9132-459d">This unit must attach to:
● ORK BOYZ</characteristic>
          </characteristics>
        </profile>
        <profile name="Urty Syringe" typeId="2dff-53d0-6d25-8c59" typeName="Weapon" hidden="false" id="010e-35a8-eaad-1f67">
          <characteristics>
            <characteristic name="Tp" typeId="6c1c-7d1d-c8b0-33ec">ML</characteristic>
            <characteristic name="A" typeId="13c5-f234-c120-afc3">3</characteristic>
