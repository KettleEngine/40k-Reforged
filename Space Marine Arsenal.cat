          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">While any enemy units are visible to this unit, it cannot capture objectives.</characteristic>
          </characteristics>
        </profile>
        <profile name="The Black Rage, Assault Intercessors" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="0c9e-17fb-67ab-5050">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After this unit is Activated, the closest visible enemy unit gains the following ability until the End step. If two or more units are the closest nenemy unit, you choose which one of those units gains it until the End step.

Arch-Traitor: For each melee attack that targets this unit made by an enemy unit with Assault Doctrine, a Wound Roll of 6 causes an additional hit.</characteristic>
          </characteristics>
        </profile>
        <profile typeId="55da-e0a0-1fa3-2d1c" typeName="Leader" hidden="false" id="3268-07ab-577c-a048">
          <characteristics>
            <characteristic name="Must Attach to" typeId="2c63-5e3f-9132-459d">This unit may be attached by:
● CHAPLAIN</characteristic>
          </characteristics>
        </profile>
      </profiles>
