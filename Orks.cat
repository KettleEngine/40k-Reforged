          <characteristics>
            <characteristic name="M" typeId="c06e-b1a2-0f87-fe2f">6&quot;</characteristic>
            <characteristic name="T" typeId="a6ad-d820-8495-f5b0">4</characteristic>
            <characteristic name="Sv" typeId="9b7f-0dde-683f-6844">6+</characteristic>
            <characteristic name="H" typeId="18e4-1bf9-a9b8-1e50">7</characteristic>
            <characteristic name="Rv" typeId="411f-3942-6dc0-7c06">2+</characteristic>
          </characteristics>
        </profile>
        <profile name="Unrestrained" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="3061-fa87-5cf5-e92f">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">For each Psychic Test made for this unit, add 1 D6 to that Psychic Test for each friendly ORK BOYZ unit on the battlefield.</characteristic>
          </characteristics>
        </profile>
        <profile name="Zzap" typeId="266a-be4d-b9fa-94de" typeName="Windfall of the Warp" hidden="false" id="7661-6a0b-5e92-f061">
          <characteristics>
            <characteristic name="Psychic Power" typeId="9060-973c-99e9-75b4">After this unit makes a Psychic Test, if that Psychic Test had two or more dice with the same result, select the closest enemy unit within 18” of this unit. The selected unit suffers 1+D3 SW.</characteristic>
          </characteristics>
        </profile>
        <profile name="Staff" typeId="2dff-53d0-6d25-8c59" typeName="Weapon" hidden="false" id="5011-3507-ce1e-097a">
          <characteristics>
            <characteristic name="Tp" typeId="6c1c-7d1d-c8b0-33ec">ML</characteristic>
            <characteristic name="A" typeId="13c5-f234-c120-afc3">3</characteristic>
            <characteristic name="WS" typeId="459f-6890-e77f-b62f">3+</characteristic>
            <characteristic name="S" typeId="571c-0471-2614-c57c">7</characteristic>
            <characteristic name="D" typeId="c2c0-3714-05e2-65a0">1</characteristic>
            <characteristic name="Abilities" typeId="d93f-70ee-72bc-5ef9">This weapon has Blast X, where X is the highest result of this unit’s last Psychic Test.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <infoLinks>
        <infoLink name="Solid Greenskin" id="7e82-9162-b419-ade1" hidden="false" type="profile" targetId="c35f-6848-d4c4-faeb"/>
        <infoLink name="Resilient (X)" id="c42a-9ac8-d3d9-5b35" hidden="false" type="rule" targetId="253c-c1fa-d29d-d21e">
