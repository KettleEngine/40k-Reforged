      <profiles>
        <profile name="1 Martyrs Blood" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="c278-37f0-982f-c838">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit’s Move step, select any ML weapon in this unit. Then, until the End step, for each H this unit is missing, add 1 to the A of the selected weapon.</characteristic>
          </characteristics>
        </profile>
        <profile name="2 Casket Of Penance" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="f98b-55e0-ab1b-c547">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">While enemy units are within 8” of this unit, for each attack made by your units which target those enemy units, add 1 to the Hit Roll of that attack.</characteristic>
          </characteristics>
        </profile>
        <profile name="3 Laud-Hailer Organ" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="e261-9cce-56a8-b3a3">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">While friendly units are within 12” of this unit, add 1 to Resolve Tests made for those units. After this unit’s Move step, enemy units within 12” suffer D3+1 Suppression.</characteristic>
          </characteristics>
        </profile>
        <profile name="4 Quicksilver Veil" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="0e00-6e49-e886-62b4">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">This unit’s M is improved by 6”. For each attack that targets this unit, add 1 to Resilient rolls for that attack.</characteristic>
          </characteristics>
        </profile>
        <profile name="6 Saintly Relics" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="c7f7-80d2-f0aa-97b9">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit gains this unit ability, select one of the weapons below. While this unit has this ability, after this unit Activates, select a model in this unit. Then, until the End step, the selected model gains the selected weapon:</characteristic>
          </characteristics>
        </profile>
        <profile name="5 Creed Annunciation" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="10b4-c80d-2a27-9c50">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">ability this unit’s weapons have is changed to “For each attack made for this weapon, a successful Wound Roll for that attack causes an additional wound.”</characteristic>
          </characteristics>
        </profile>
        <profile name="Saintly Heavy Bolter" typeId="2dff-53d0-6d25-8c59" typeName="Weapon" hidden="false" id="719c-db2f-b2ce-b065">
          <characteristics>
            <characteristic name="Tp" typeId="6c1c-7d1d-c8b0-33ec">Hv</characteristic>
            <characteristic name="A" typeId="13c5-f234-c120-afc3">7</characteristic>
            <characteristic name="WS" typeId="459f-6890-e77f-b62f">3+</characteristic>
            <characteristic name="S" typeId="571c-0471-2614-c57c">5</characteristic>
