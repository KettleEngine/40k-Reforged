  <sharedProfiles>
    <profile name="Power from Pain" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="b06f-e1dd-55f1-f0e8">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">While this unit is within 24” of an enemy unit with Suppressed, it gains Resilient 6+.</characteristic>
      </characteristics>
    </profile>
    <profile name="Herd the Prey" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="faa2-ab68-8bd3-d6ef">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After this unit&apos;s Attacks step, this unit or a unit it is embarked within may Fall Back up to XD3” (instead of its normal M) where X is the number of different enemy units with Suppressed in the battlefield.</characteristic>
      </characteristics>
    </profile>
    <profile name="Twisted Fleshcraft" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="59df-978c-0873-f611">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">Add 2 to Resilient rolls for this unit.</characteristic>
      </characteristics>
    </profile>
    <profile name="Instruments of Torture" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="0128-cfa6-7815-0843">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">While any enemy units with Suppressed X are within 12” of this unit, those units’ M is worsened by X (to a minimum of 0”).</characteristic>
      </characteristics>
    </profile>
    <profile name="Lethal Celerity" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="0f7c-388c-93a3-aeaa">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">This unit may move through enemy units as if they were not there.</characteristic>
      </characteristics>
    </profile>
    <profile name="Graceful Acrobatics" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="245a-99df-d602-3b5a">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">For each attack that targets this unit, the Hit Roll of that attack is worsened by 1.</characteristic>
      </characteristics>
    </profile>
    <profile name="No Escape" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="aa49-2194-0e79-89d8">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">Each time you Pile In this unit, each model may move an additional X” where X is the highest Suppressed X on any enemy unit within engagement range of this unit.</characteristic>
      </characteristics>
    </profile>
    <profile name="Arena Beasts" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="7a93-42c2-196d-e521">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">If this unit has no leader model, after this unit&apos;s End step, if this turn was not your second turn in a row, take another turn.</characteristic>
      </characteristics>
    </profile>
    <profile name="Grav-Engines" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="5859-caa5-7b1b-f8f1">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">For each Advance Roll made for this unit, add 1 D6 to that roll.</characteristic>
      </characteristics>
    </profile>
    <profile name="Slicing Skimmer" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="73a0-b916-aeb0-b906">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After this unit finishes a March, if it is not within engagement range of any enemy units, make attacks with its Bladevanes targeting one enemy unit it passed within 1” of during that March. Improve the A of its Bladevanes to 8 for those attacks.</characteristic>
      </characteristics>
    </profile>
    <profile name="Aethersail Agility" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="8fd5-76ff-fb31-918d">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">For each attack that targets this unit from further than 9” away, the Hit Roll of that attack is worsened by 1.</characteristic>
      </characteristics>
    </profile>
  </sharedProfiles>
  <sharedRules>
    <rule name="Poison" id="dda4-31db-bf0a-2af4" hidden="false">
      <description>For each attack made for this weapon that targets an infantry or monster unit, a Hit Roll of 6 for that attack always wounds.</description>
    </rule>
  </sharedRules>
