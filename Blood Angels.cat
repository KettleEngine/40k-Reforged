        <profile name="3 Eagle Eye Helm" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="c609-983f-eb32-38a7">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After an enemy unit finishes a March and is visible to this unit, you may roll a D6. On a 5+, this unit may Fall Back.</characteristic>
          </characteristics>
        </profile>
        <profile name="4 Fulminaris Vexilla" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="e136-a80f-ead2-bcad">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit finishes a March, each enemy unit within 8” suffers 3+D3 SW.</characteristic>
          </characteristics>
        </profile>
        <profile name="5 Stasis Oubliette" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="24b6-3ace-5ab6-ea27">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">While enemy units are within 3” of this unit, those units cannot be selected for Activation unless their controlling player has no other units available for Activation.</characteristic>
          </characteristics>
        </profile>
        <profile name="6 Misery’s Burden" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="e512-f8c7-47d2-ce75">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">Each time you roll a D6 for Kaptaris Parry for this unit, add 1 to the result. For each attack this unit makes, add 1 to the Hit Roll of that attack.</characteristic>
          </characteristics>
        </profile>
      </profiles>
