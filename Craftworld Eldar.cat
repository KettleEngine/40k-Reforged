  <sharedProfiles>
    <profile name="Jet Bikes" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="e8ad-40cd-784f-fb45">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">For each Move Roll made for this unit, add 1 D6 to that roll.</characteristic>
      </characteristics>
    </profile>
    <profile name="Lightning Speed" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="981f-33b8-4f96-fa66">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After this unit finishes an Advance, if that move ended at least 10” away from where it started, until the next time this unit is Activated, for each attack that targets this unit, the Hit Roll for that attack is worsened by 1.</characteristic>
      </characteristics>
    </profile>
    <profile name="Windfall of the Warp, Seer Sight" typeId="266a-be4d-b9fa-94de" typeName="Windfall of the Warp" hidden="false" id="83fb-1b38-71c1-49dd">
      <characteristics>
        <characteristic name="Psychic Power" typeId="9060-973c-99e9-75b4">After this unit makes a Psychic Test, if that Psychic Test has two or more dice with the same result, until the End step, for each attack made for this unit, add 1 the Hit Roll of that attack.</characteristic>
      </characteristics>
    </profile>
    <profile name="Fleet Footwork" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="1367-65b6-5f27-116d">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After this unit’s Attack step, if one or more enemy units that were targeted by an attack made by this unit this turn had Fatal Thread, this unit may Reposition.</characteristic>
      </characteristics>
    </profile>
  </sharedProfiles>
</catalogue>
