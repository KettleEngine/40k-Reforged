          </modifiers>
          <comment>Blood Angels</comment>
        </profile>
        <profile name="3 Angel&apos;s Wings" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="true" id="7fd3-456a-3e0a-7c28">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">For each Move Roll made for this unit, add 1 D6 to that roll. If this unit has Fly, add 2 D6 to that roll instead. If it does not, this unit gains Fly.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="e9e1-2a24-faf7-e76f" shared="true" includeChildSelections="true" childName="Blood Angels"/>
              </conditions>
            </modifier>
          </modifiers>
          <comment>Blood Angels</comment>
        </profile>
        <profile name="6 Sanguinor" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="true" id="80bb-973f-949f-a81f">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit’s last model reaches 0 Health, instead of dying and removing it from the battlefield, all remaining attacks targeting this unit fail. Then, it Heals 2+2D3 and each enemy unit within 6” suffers D3+1 SW. This ability can only be used once per battle round, even if another unit gains this ability.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="e9e1-2a24-faf7-e76f" shared="true" includeChildSelections="true" childName="Blood Angels"/>
              </conditions>
            </modifier>
          </modifiers>
          <comment>Blood Angels</comment>
        </profile>
        <profile name="2 Aureate Halo" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="true" id="b9fa-7100-7e7a-32b7">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">This unit gains Resilient 6+. After a visible enemy unit Activates, until the End step, for each attack that targets this unit, add 1 to Resilient Rolls made for this unit.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="e9e1-2a24-faf7-e76f" shared="true" includeChildSelections="true" childName="Blood Angels"/>
              </conditions>
            </modifier>
          </modifiers>
          <comment>Blood Angels</comment>
        </profile>
        <profile name="5 Red Grail" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="true" id="7815-2ac4-611c-d248">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit is Activated, it Heals 1. For each melee attack this unit makes, a Hit Roll of 5+ causes an additional hit.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
