          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After this unit’s Move step, you may select up to two friendly infantry units within 4” of this unit. If you do, the selected units Heals 1 and loses Succumbed (if they have it).</characteristic>
          </characteristics>
        </profile>
        <profile name="Exsanguinator" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="b71f-8fe1-a911-3552">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After this unit’s Move step, you may select up to one friendly infantry unit within 4”. If you do, the selected unit Heals 2, skip the Attacks step this turn and if this was not your second turn in a row, after the End step, take another turn.</characteristic>
          </characteristics>
        </profile>
