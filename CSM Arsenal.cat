      <profiles>
        <profile name="Iron Armoury" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="true" id="86ff-0b20-e7be-a2ed">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">Each of your LEGIONARIES units with 4 or more Boltguns gains the following ability:</characteristic>
          </characteristics>
          <comment>Iron Warriors</comment>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="27b0-cf36-cd17-73c6" shared="true" includeChildSelections="true" childName="Iron Warriors"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="Iron Armoury (Shrapnel Boltguns)" typeId="2dff-53d0-6d25-8c59" typeName="Weapon" hidden="true" id="620b-eaf7-d3c6-26bd">
          <characteristics>
            <characteristic name="Tp" typeId="6c1c-7d1d-c8b0-33ec">Aslt</characteristic>
            <characteristic name="A" typeId="13c5-f234-c120-afc3">2</characteristic>
            <characteristic name="WS" typeId="459f-6890-e77f-b62f">3+</characteristic>
