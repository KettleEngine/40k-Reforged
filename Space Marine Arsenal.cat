    <selectionEntry type="upgrade" import="true" name="Current Version: 3.1.0" hidden="false" id="beca-d151-7fad-9832" sortIndex="-1">
      <categoryLinks>
        <categoryLink name="Configuration" hidden="false" id="895e-8347-d87b-2963" targetId="9cd6-0442-3f35-6b52" primary="true"/>
      </categoryLinks>
