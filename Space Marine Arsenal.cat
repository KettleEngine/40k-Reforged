          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">All enemy units within 3D6” suffer 2 SW. If those units are within 8” of this unit they suffer an additional 2 SW.</characteristic>
          </characteristics>
          <comment>Salamanders</comment>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
