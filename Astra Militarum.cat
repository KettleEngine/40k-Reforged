        <constraint type="max" value="1" field="selections" scope="force" shared="true" id="f948-e6d2-0d9e-7785-max" includeChildSelections="false"/>
      </constraints>
      <profiles>
        <profile name="1 Macharian Cross" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="6c33-75f8-7be0-c48e">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After a friendly Astra Militarum infantry unit is Activated within 12” of this unit, that unit may gain one of the following abilities:


Move Move Move!: For each Move Roll made for this unit, add 1 D6 to that roll.


Aim There!: For each ranged attack this unit makes, add 1 to the Hit Roll of that attack.</characteristic>
          </characteristics>
        </profile>
        <profile name="2 Push Logistics Stockpile" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="df88-a46c-4439-8190">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After rolling for initiative, roll a D6. On a 1, 2 or 3, select one of your infantry units. On a 4, 5 or 6, select one of your vehicle units. The selected unit Repairs 4+D3.</characteristic>
          </characteristics>
        </profile>
        <profile name="3 Pull Logistics Radio Request" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="0122-d30c-c847-5a4e">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit Activates, select one of your units. The selected unit Repairs D3+1.</characteristic>
          </characteristics>
        </profile>
        <profile name="4 Artillery Transponder" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="2dbb-61d1-fffc-6d37">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit Activates, select one model in this unit. Until the End step, the selected model gains the following weapon:</characteristic>
          </characteristics>
        </profile>
        <profile name="5 Valkyrie Authorisation" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="ed40-9801-b136-e9af">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit Activates, select one model in this unit. Until the End step, the selected model gains the following weapon:</characteristic>
          </characteristics>
        </profile>
        <profile name="6 Urgent Medevac" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="99bd-0f4e-677a-d196">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit is Activated, if it is an infantry unit, you may remove it from the battlefield. Then, it Heals 10. Then, Deploy this unit wholly within your deployment zone, and this unit loses this relic.</characteristic>
          </characteristics>
        </profile>
        <profile name="4 Artillery Transponder (Earthshaker Cannon Rear Support)" typeId="2dff-53d0-6d25-8c59" typeName="Weapon" hidden="false" id="3e84-6c9b-4133-d978">
          <characteristics>
            <characteristic name="Tp" typeId="6c1c-7d1d-c8b0-33ec">Hv</characteristic>
            <characteristic name="A" typeId="13c5-f234-c120-afc3">2</characteristic>
            <characteristic name="WS" typeId="459f-6890-e77f-b62f">5+</characteristic>
            <characteristic name="S" typeId="571c-0471-2614-c57c">6</characteristic>
            <characteristic name="D" typeId="c2c0-3714-05e2-65a0">4</characteristic>
            <characteristic name="Abilities" typeId="d93f-70ee-72bc-5ef9">Indirect, Barrage, Suppressive 4, For each successful Wound Roll made for this weapon’s attacks, the target unit suffers 2 SW.</characteristic>
          </characteristics>
        </profile>
        <profile name="5 Valkyrie Authorisation (Valkyrie Multi-Laser)" typeId="2dff-53d0-6d25-8c59" typeName="Weapon" hidden="false" id="6c50-8d0d-1fcc-baa5">
          <characteristics>
