        <profile name="Curse of the Walking Pox" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="6ef9-5da0-b7cd-7419">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After an enemy unit dies within 7” of this unit with Suppression X, this unit Heals X. If this unit Heals this way and is already its starting Health, instead add 1 POXWALKERS model to this unit.</characteristic>
          </characteristics>
        </profile>
