          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">The unit this unit is attached to does not count towards the maximum number of that unit in your army list.</characteristic>
          </characteristics>
        </profile>
        <profile name="" typeId="55da-e0a0-1fa3-2d1c" typeName="Leader" hidden="false" id="0e56-0980-ca2f-ea22">
