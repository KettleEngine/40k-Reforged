        <profile name="Forgemaster’s Relic: 4 Hide of the Drakelords" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="true" id="ad97-9127-bed0-c8e6">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">For each wound a model in this unit suffers, roll a D6. On a 5+, that attack fails, and, after the current step, the unit that made that attack suffers SW equal to that attack’s D.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
