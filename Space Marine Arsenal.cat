          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">While other friendly infantry units are within 1” of this unit and this unit is closer or the same distance to an active enemy unit visible to this unit, those friendly infantry units gain the following ability:


Guarded: For each wound a model in this unit is selected to suffer, you may roll a D6. On a 5+, that attack fails.</characteristic>
          </characteristics>
        </profile>
        <profile name="Unyielding Bulwark" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="e466-9233-31ed-9f9a">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">While this unit is within 12” of a friendly leader unit, for each D6 you roll for this unit’s Storm Shields, add 1 to that roll.</characteristic>
          </characteristics>
        </profile>
      </profiles>
