        <selectionEntry type="upgrade" import="true" name="Waystone Clutches" hidden="false" id="e215-c080-d729-0f7e">
          <profiles>
            <profile name="Waystone Clutches" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="a33a-6f9a-696d-8089">
              <characteristics>
                <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After this unit finishes a march within 4&quot; of the centre point of a vault, you may roll 1D6. then Select one of your units and it gains the relic equal to the D6. Any other friendly units with that relic lose it. Any other friendly unit with that relic loses it.</characteristic>
