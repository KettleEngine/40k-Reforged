      <profiles>
        <profile name="Last Rites" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="05c2-b8a9-5d79-2465">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After each time one of your units fails an Act of Faith roll, for the rest of the battle, add 1 to the D3 roll for this unit’s Mobile Triage ability.</characteristic>
          </characteristics>
        </profile>
        <profile name="Mobile Triage" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="c672-9cef-73da-2291">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After this unit’s Move step, roll a D3. Then, for a number of times equal to the result of that roll, select a friendly infantry unit within 12” of this unit, and that unit Heals 1. If you do, skip the Attacks step this turn and if this was not your second turn in a row, after the End step, take another turn.</characteristic>
          </characteristics>
        </profile>
      </profiles>
