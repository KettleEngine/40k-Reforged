        <constraint type="max" value="1" field="selections" scope="force" shared="true" id="4588-bb6c-21e4-aa19" includeChildSelections="false"/>
      </constraints>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Army Rules" hidden="false" id="37f4-86d7-cfad-f68a" sortIndex="-2">
      <constraints>
        <constraint type="min" value="1" field="selections" scope="force" shared="true" id="54c0-8388-f7c2-5f0c-min" includeChildSelections="false"/>
        <constraint type="max" value="1" field="selections" scope="force" shared="true" id="54c0-8388-f7c2-5f0c-max" includeChildSelections="false"/>
      </constraints>
      <categoryLinks>
        <categoryLink name="Configuration" hidden="false" id="dbc4-612b-2a26-ecff" targetId="9cd6-0442-3f35-6b52" primary="true"/>
      </categoryLinks>
      <profiles>
        <profile name="Space Marine Chapters" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="bf03-6c7d-1a9f-9519">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">During list building, select one chapter from this document. Use the relics table and psychic powers from that chapter’s section. You may add units from that section, or from the Space Marines section to your army list.</characteristic>
          </characteristics>
        </profile>
        <profile name="Captain Ability: Battlefield Scholar" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="true" id="8dd3-a193-1b7e-363e">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After rolling for initiative or after this unit Activates, select one of the following abilities. While your infantry units are within 16” of this unit, they gain the selected ability and lose the other (if they have it):


Coordinated Assault: For each attack this unit makes which targets an enemy unit within 12” of this unit, reroll a Hit Roll of 1 for that attack.


Defensive Discipline: For each attack that targets this unit from further than 12” away, this unit gains Resilient 6+ for that attack. If it already had Resilient, add 1 to Resilient Rolls made for this unit.</characteristic>
          </characteristics>
          <comment>Ultramarines</comment>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="22ae-1fb4-b388-d475" shared="true" includeChildSelections="true" childName="Ultramarines"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="Captain Ability: Red Thirst" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="true" id="8674-d7f9-d5b0-fbe9">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After any of your infantry units within 24” of this unit is Activated, that unit may ‘unleash’. If you do, roll a D6. Then, that unit gains one or both of the following abilities equal to the result:


1+ Unleashed: For each Move Roll made for this unit, add 1 D6 to and discard the lowest result of that roll. For each melee attack this unit makes, reroll a failed Wound Roll for that attack. This unit loses this ability after the End step.


5+ Succumbed: This unit cannot capture objectives.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="e9e1-2a24-faf7-e76f" shared="true" includeChildSelections="true" childName="Blood Angels"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="Captain Ability: Forgemaster" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="true" id="6247-50e0-f346-b3d3">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After this unit’s Move step, select one friendly unit visible to and within 6” of this unit with a relic. For the rest of the battle, use the corresponding ability from the ‘forgemaster’s relics’ table for that relic (instead of the normal salamanders relics). 


After a friendly unit’s relic becomes reforged, for the rest of the battle, use the corresponding ability from the forgemaster’s relics table for that relic (instead of the normal salamanders relics).


Give one relic per initiative</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="39a2-a31c-bc16-9208" shared="true" includeChildSelections="true" childName="Salamanders"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="Captain Ability: Deeds of the Vlka Fenryka" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="true" id="fd39-eea1-b628-bb38">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">While your infantry units are within 24” of this unit, after a model in those units die, if there is one model remaining in that unit, that unit gains the following abilities:


For The Skald Songs: While there is one model in this unit, for each melee attack this unit makes, a Hit Roll of 5+ for that attack causes an additional hit.


Last Stand: After a model in this unit dies, if there is one model in this unit, it gains Resilient 3+ until the End step and it gains ready.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="6e28-72e3-f8fe-a6d3" shared="true" includeChildSelections="true" childName="Space Wolves"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
      </profiles>
      <infoLinks>
        <infoLink name="Astartes Battleline" id="42f4-665c-ae72-09da" hidden="false" type="profile" targetId="0181-7b67-dc1a-9ea1"/>
      </infoLinks>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Psychic Powers (Reference)" hidden="false" id="158e-3109-20be-9fe5" sortIndex="-4">
      <constraints>
        <constraint type="min" value="1" field="selections" scope="force" shared="true" id="3c64-5a62-e282-e50c-min" includeChildSelections="false"/>
        <constraint type="max" value="1" field="selections" scope="force" shared="true" id="3c64-5a62-e282-e50c-max" includeChildSelections="false"/>
      </constraints>
      <categoryLinks>
        <categoryLink name="Configuration" hidden="false" id="b9f9-be09-f3a5-6f2b" targetId="9cd6-0442-3f35-6b52" primary="true"/>
      </categoryLinks>
      <profiles>
        <profile name="1 Precognition" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="true" id="e071-7e77-1f5e-dea5">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Until the next time this unit is Activated, for each ranged attack that targets this unit, the Hit Roll of that attack is worsened by 1.</characteristic>
          </characteristics>
          <comment>Ultramarines</comment>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="22ae-1fb4-b388-d475" shared="true" includeChildSelections="true" childName="Ultramarines"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="1 The Gate" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="true" id="27ae-c5a0-1e34-bbc3">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Remove this unit from the battlefield and place it into reserves. Then, Deploy it anywhere in the battlefield at least 3D6” away from enemy models.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="6e28-72e3-f8fe-a6d3" shared="true" includeChildSelections="true" childName="Space Wolves"/>
              </conditions>
            </modifier>
          </modifiers>
          <comment>Space Wolves</comment>
        </profile>
        <profile name="1 Fire Shield" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="true" id="43f3-8efc-69dc-b94e">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Until the next time this unit is Activated or dies, for each wound for a ranged attack a model in this unit is selected to suffer, roll a D6. On 5+, that attack fails.</characteristic>
          </characteristics>
          <comment>Salamanders</comment>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="39a2-a31c-bc16-9208" shared="true" includeChildSelections="true" childName="Salamanders"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="1 Transfixing Gaze" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="true" id="fe3a-b4d0-c13a-7c55">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select an enemy unit within 16” of and visible to this unit. The selected enemy unit suffers 3D3 Suppression.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="e9e1-2a24-faf7-e76f" shared="true" includeChildSelections="true" childName="Blood Angels"/>
              </conditions>
            </modifier>
          </modifiers>
          <comment>Blood Angels</comment>
        </profile>
        <profile name="2 Telepathic Assault" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="true" id="6e8e-b21b-b2ab-7aa6">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select an enemy unit within 16” of and visible to this unit. The selected unit suffers 3D3 Suppression. The selected unit suffers X SW where X is equal to the selected unit&apos;s Suppressed X.</characteristic>
          </characteristics>
          <comment>Ultramarines</comment>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="22ae-1fb4-b388-d475" shared="true" includeChildSelections="true" childName="Ultramarines"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="3 Psychic Shackles" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="true" id="7687-a75c-55f6-9276">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select an infantry or monster unit within 16” of and visible to this unit. The selected unit suffers 2+3D6 Suppression</characteristic>
          </characteristics>
          <comment>Ultramarines</comment>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="22ae-1fb4-b388-d475" shared="true" includeChildSelections="true" childName="Ultramarines"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="4 Scryer&apos;s Gaze" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="true" id="47f1-88d0-696f-3be3">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">The next time you roll for initiative, roll an additional D6 for that roll.</characteristic>
          </characteristics>
          <comment>Ultramarines</comment>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="22ae-1fb4-b388-d475" shared="true" includeChildSelections="true" childName="Ultramarines"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="5 Electrodisplacement" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="true" id="1444-42a1-692f-8ddb">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select a friendly unit visible to this unit and mark anywhere on the battlefield within 1” of that unit. Remove the selected unit from the battlefield, place it into reserves and then, Deploy it wholly within 6” of this unit outside of engagement range of enemy models. Then, remove this unit from the battlefield, place it into reserves and then, Deploy it wholly within 6” of the mark.</characteristic>
          </characteristics>
          <comment>Ultramarines</comment>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="22ae-1fb4-b388-d475" shared="true" includeChildSelections="true" childName="Ultramarines"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="6 Storm of the Emperor&apos;s Wrath" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="true" id="5066-45c8-4816-6fdc">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select an enemy unit within 16” of and visible to this unit. That unit suffers D3+2 SW and each of those SW has 2 Damage instead of 1.</characteristic>
          </characteristics>
          <comment>Ultramarines</comment>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="22ae-1fb4-b388-d475" shared="true" includeChildSelections="true" childName="Ultramarines"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="2 Murderous Hurricane" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="true" id="f638-8c71-a6d7-95e3">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Until the next time this unit Activates or dies, while enemy units are within 16” of this unit, those units gain the following ability:


Icy Chill: For each Move Roll made for this unit, discard the highest result of that roll. Then, this unit suffers X Suppression where X is equal to that discarded dice result.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="6e28-72e3-f8fe-a6d3" shared="true" includeChildSelections="true" childName="Space Wolves"/>
              </conditions>
            </modifier>
          </modifiers>
          <comment>Space Wolves</comment>
        </profile>
        <profile name="3 Thunderclap" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="true" id="896f-8425-5396-8034">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Each enemy unit within 6” suffers 2+D3 SW. Then, each enemy unit within 12” of and visible to this unit suffers 2+D3 Suppression.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="6e28-72e3-f8fe-a6d3" shared="true" includeChildSelections="true" childName="Space Wolves"/>
              </conditions>
            </modifier>
          </modifiers>
          <comment>Space Wolves</comment>
        </profile>
        <profile name="5 Storm Caller" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="true" id="4cad-4c5a-b536-b8c1">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Until the next time this unit Activates, for each ranged attack that targets this unit, the Hit Roll of that attack is worsened by 1.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="6e28-72e3-f8fe-a6d3" shared="true" includeChildSelections="true" childName="Space Wolves"/>
              </conditions>
            </modifier>
          </modifiers>
          <comment>Space Wolves</comment>
        </profile>
        <profile name="6 Fury of the Wolf Spirits" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="true" id="f7f9-7461-520d-683e">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select one model in this unit. Until the End step, the selected model gains the following weapons:</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
