  <sharedProfiles>
    <profile name="Chapter Captain" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="3a69-b9b8-2f45-4cd1">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">This unit gains the Captain ability from your selected chapter’s section.</characteristic>
      </characteristics>
    </profile>
    <profile name="Astartes Battleline" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="0181-7b67-dc1a-9ea1">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After you roll for initiative or Activate a leader unit, select one of the following ‘doctrine’ abilities for all of your units with Astartes Battleline:

Tactical Doctrine: You may reroll Move Rolls made for this unit.

Assault Doctrine: For each attack this unit makes that targets an enemy unit within 12” of this unit, add 1 to the Hit Roll of that attack.

Devastator Doctrine: For each attack this unit makes that targets an enemy unit further than 12” away from this unit, add 1 to the Hit Roll of that attack.

All of your units with Astartes Battleline gain that ability until the next time you select a doctrine ability. 

While your infantry units are within 16” of this unit, they gain the doctrine ability this unit has.</characteristic>
      </characteristics>
    </profile>
    <profile name="Lightning Arc" typeId="266a-be4d-b9fa-94de" typeName="Windfall of the Warp" hidden="false" id="9eaa-a8db-8a38-b2e5">
      <characteristics>
        <characteristic name="Psychic Power" typeId="9060-973c-99e9-75b4">After this unit makes a Psychic Test, if that Psychic Test had two or more dice with the same result, select up to 2 different visible enemy units within 16” of this unit. Each selected unit suffers D3+1 SW.</characteristic>
      </characteristics>
    </profile>
    <profile name="Tactical Insight" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="8644-71e5-a9e7-7d14">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">Once per battle round, after this unit’s Select step, if the centre point of one or more objectives is visible to this unit, you may ‘assess the battlefield’. If you do, this unit becomes ready. Then, skip to the End step</characteristic>
      </characteristics>
    </profile>
    <profile name="Litany of Hate" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="35c4-0160-49a8-530f">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">For each attack made for a friendly unit within 12&quot; of this unit which targets an enemy unit within 12&quot;, if that attack&apos;s S is equal to or greater than the target&apos;s T, add 1 to the Wound Roll for that attack.</characteristic>
      </characteristics>
    </profile>
    <profile name="Support Element" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="731d-62c8-ab31-eed7">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After the End step, if this was not your second turn in a row, take another turn.</characteristic>
      </characteristics>
    </profile>
  </sharedProfiles>
  <catalogueLinks>
    <catalogueLink type="catalogue" name="New Catalogue (link)" id="6200-b161-0e09-4150" targetId="f178-f218-fb11-d21a"/>
  </catalogueLinks>
