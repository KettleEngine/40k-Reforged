    <selectionEntry type="unit" import="true" name="Wyvern" hidden="false" id="3083-2edc-8324-579e">
      <profiles>
        <profile name="Artillery Support" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="6491-b3b5-cac3-19d8">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">While selecting targets for this unit&apos;s Quad Stormshard Mortar, if you have no ready units except units with Artillery Support, you may ‘call for an artillery strike’. If you do, you may instead target an enemy unit within 24&quot; of and visible to any of your infantry units within 24&quot; of this unit. Additionally, for each attack made for that weapon this turn, add 1 to the Hit Roll of that attack.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink name="Vehicle" hidden="false" id="c7e1-2da6-62f8-141c" targetId="b239-6bd1-e7a0-0a02" primary="false"/>
        <categoryLink name="Support" hidden="false" id="2bae-6b39-eb1e-fa15" targetId="ccc6-6202-853c-23e4" primary="true"/>
      </categoryLinks>
      <costs>
        <cost name="pts" typeId="points" value="120"/>
      </costs>
      <selectionEntries>
