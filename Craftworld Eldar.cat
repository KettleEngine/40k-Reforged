        <profile name="Clarity of Thought" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="e802-d71a-a196-e9ac">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After you Activate this unit, this unit gains the selected abilities until the End step:

Surviving Sibling: Each of this unit&apos;s weapons WS is improved by 1.

Twin&apos;s Essence: Add 1 D6 to Move Rolls made for this unit.</characteristic>
          </characteristics>
        </profile>
      </profiles>
