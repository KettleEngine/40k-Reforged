  <selectionEntries>
    <selectionEntry type="upgrade" import="true" name="Army Abilities" hidden="false" id="3e4b-29af-4da8-2435" sortIndex="-2">
      <categoryLinks>
        <categoryLink targetId="9cd6-0442-3f35-6b52" id="0760-2d2e-bb87-c895" primary="true" name="Configuration"/>
      </categoryLinks>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="5ef3-7421-f11f-96ec" includeChildSelections="false"/>
      </constraints>
      <profiles>
        <profile name="Mocking Misstep" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="93f2-8278-f866-f23e">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">Once per turn, after an enemy unit’s Move step, you may select one of your Harlequins units that is visible to that enemy unit. If you do, roll a D6. On a 6+, the roll is successful and the selected unit may Reposition.</characteristic>
          </characteristics>
        </profile>
        <profile name="Kaleidoscopic Cavalcade" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="9280-5f03-55b2-37aa">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">For each attack that targets your Harlequins units, the Hit Roll for that attack is worsened by 1.</characteristic>
          </characteristics>
        </profile>
        <profile name="Prismatic Pirouette" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="e5f5-f88d-4326-e279">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">Your Harlequins units may move over enemy units and terrain as if they were not there. During your turns, if any of your Harlequins units would Reposition, that unit may Advance instead.</characteristic>
          </characteristics>
        </profile>
        <profile name="Allegro Advance" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="b0fe-1497-b8f4-1287">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">For each Move Roll made for your Harlequins units, roll an additional D6 and discard the lowest dice for that roll.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Relics (Reference)" hidden="false" id="b58a-ba1e-7fbf-a030" sortIndex="-4">
      <profiles>
        <profile name="2 Blinded Damsel" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="3c0c-9a15-b526-32e0">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After a wound is assigned to a model in this unit, roll a D6. On a 5+, that attack fails</characteristic>
          </characteristics>
        </profile>
        <profile name="3 Curtain’s Fall" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="8429-07bd-099c-7883">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">Each time you roll a D6 for Mocking Misstep for this unit, you may reroll the result. After this unit finishes a Reposition, if it had Stuck In, it does not lose it.</characteristic>
          </characteristics>
        </profile>
        <profile name="1 Webway Virtuosos" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="0623-7726-9761-14f3">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit is Activated, you may remove it from the battlefield and place it into reserves. Then roll 3D6. You may Deploy it anywhere on the battlefield at least X” away from enemy units where X is the result of that roll.</characteristic>
          </characteristics>
        </profile>
        <profile name="4 She Who Thirsts" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="ef77-efcd-11e5-863b">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit’s Move step, you may ‘mime the Dark Prince’. If you do, select an enemy unit within 16” of and visible to this unit. After the Attacks step, if an enemy unit died this turn, this unit may Fall Back and the selected unit suffers Suppression 6+2D6.</characteristic>
          </characteristics>
        </profile>
        <profile name="5 Damned Nemesis" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="db57-93b0-d96a-fab2">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">For each attack made by this unit for an ML weapon, Hit Rolls of 5+ for that attack causes an additional hit and if that attack targets a chaos unit, reroll a Wound Roll of 1 for that attack.</characteristic>
          </characteristics>
        </profile>
        <profile name="6 Cegorach’s Favour" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="c057-fd2c-7b76-5731">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After an enemy unit’s Move step, you may roll a D6. On a 5+, this unit may Reposition. After this unit finishes a Reposition, if it had Stuck In, it does not lose it.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="force" shared="true" id="2210-dc7d-4951-de68" includeChildSelections="false"/>
      </constraints>
      <categoryLinks>
        <categoryLink name="Configuration" hidden="false" id="d52a-2a89-96ed-2398" targetId="9cd6-0442-3f35-6b52" primary="true"/>
      </categoryLinks>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Psychic Powers (Reference)" hidden="false" id="209a-4a6e-d552-b2a7" sortIndex="-3">
      <profiles>
        <profile name="1 Fog of Dreams" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="0578-61a0-1ecd-0580">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select an enemy infantry or monster unit within 16” of this unit. The selected unit suffers 2+2D3 Suppression and until the end of the battle round, the selected unit can only select targets within 8” of it for its attacks.</characteristic>
          </characteristics>
        </profile>
        <profile name="2 Veil of Tears" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="93a3-8842-0595-366c">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select a friendly infantry unit within 16” of this unit. Until the next time this unit is Activated or dies, the selected unit gains the following ability:


Veiled: For each ranged attack that targets this unit, the Hit Roll for that attack is worsened by 1.</characteristic>
          </characteristics>
        </profile>
        <profile name="3 Mind Labyrinth" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="b94c-446b-99fe-0bf3">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select an enemy unit within 16” of and visible to this unit. The selected unit suffers 2+2D3 Suppression. Then, until the end of the battle round, the selected unit’s M is worsened by X where X is equal to the Suppressed X it has.</characteristic>
          </characteristics>
        </profile>
        <profile name="4 Dance of Shadows" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="d10d-b877-23c7-b19f">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Until the end of the battle round, for each ranged attack an enemy unit makes targeting this unit or a friendly infantry unit within 3” of this unit, the Wound Roll of that attack is only successful on a 4+.</characteristic>
          </characteristics>
        </profile>
        <profile name="5 Shards of Light" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="3f47-d72d-e8f8-08bd">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select up to 3 different enemy units within 16” and visible to this unit. Each selected unit suffers D3+2 SW.</characteristic>
          </characteristics>
        </profile>
        <profile name="6 Peal of Discord" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="69f4-0e41-f527-e5d3">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Each enemy unit within 8” of this unit suffers D3+2 Suppression. Then, each enemy unit within 8” of this unit suffers D3+2 SW.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink name="Configuration" hidden="false" id="e934-bae6-7d8e-d7dd" targetId="9cd6-0442-3f35-6b52" primary="true"/>
      </categoryLinks>
    </selectionEntry>
