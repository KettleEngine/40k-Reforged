  <sharedProfiles>
    <profile name="Adaptive Bioforms" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="0d87-dd31-8828-68b4">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After rolling for initiative during battle round 1, each of your units with Adaptive Bioform gain one of the following ‘adaptation’ abilities:

Rend: Each weapon in this unit has its Strength improved by 1.

Carapace: This unit gains Resilient 5+.

Adrenaline: For each Advance Roll made for this unit, add 1 D6 to that Advance Roll.</characteristic>
      </characteristics>
    </profile>
    <profile name="Frenzied Feeders" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="a8f5-3d8c-4b84-575a">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After rolling for initiative in battle round 1, create a unit of RIPPER SWARM with X models, where X is the total number of HORMAGAUNTS and TERMAGANTS in your army list.</characteristic>
      </characteristics>
    </profile>
    <profile name="Synapse" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="ef65-9c3a-581f-6896">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">While your units are within 12” of this unit, they gain the following ability:

Hive Minded: For each Resolve Test made for this unit, add 1 to that Resolve Test.</characteristic>
      </characteristics>
    </profile>
    <profile name="Genetic Replication" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="6a78-8ac7-367b-4410">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">You may select units in reserves to gain relics.</characteristic>
      </characteristics>
    </profile>
    <profile name="Dominating Shadow" typeId="266a-be4d-b9fa-94de" typeName="Windfall of the Warp" hidden="false" id="12e1-903d-2084-3dd7">
      <characteristics>
        <characteristic name="Psychic Power" typeId="9060-973c-99e9-75b4">After this unit makes a Psychic Test, if that Psychic Test had two or more dice with the same result, select any enemy unit within 24” of this unit. The selected unit suffers D3+2 Suppression. If the selected unit has Psyker, that unit suffers D3+3 Suppression instead.</characteristic>
      </characteristics>
    </profile>
    <profile name="Instinctive Swarm" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="5cf3-83fb-d394-fdd8">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">If this unit has no leader model, after this unit&apos;s End step, if this turn was not your second turn in a row, take another turn.</characteristic>
      </characteristics>
    </profile>
    <profile name="Chameleonic Carapace" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="d725-c927-60e7-1f31">
      <characteristics>
        <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">For each attack that targets this unit, the Hit Roll for that attack is worsened by 1.</characteristic>
      </characteristics>
    </profile>
    <profile name="Atavistic Terror" typeId="266a-be4d-b9fa-94de" typeName="Windfall of the Warp" hidden="false" id="5f07-ae71-efa1-911b">
      <characteristics>
        <characteristic name="Psychic Power" typeId="9060-973c-99e9-75b4">After this unit makes a Psychic Test, if that Psychic Test had two or more dice with the same result, each enemy unit within 12” of this unit suffers D3+1 Suppression.</characteristic>
      </characteristics>
    </profile>
  </sharedProfiles>
