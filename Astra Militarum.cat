            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="3a21-568f-8687-30c0-max" includeChildSelections="false"/>
          </constraints>
          <profiles>
            <profile name="1 or 2 Telekinesis" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="e1d0-5149-1542-1d8d">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select up to one debris terrain piece within 24” of this unit. Remove the selected debris from the battlefield. Then, place the debris anywhere on the battlefield. Do not place it on any terrain, objectives, or models.</characteristic>
              </characteristics>
            </profile>
            <profile name="3 or 4 Telepathy" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="0b50-440c-774e-6c6d">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select any infantry unit within 16” of this unit. If the selected unit is an enemy unit, it suffers 2D3 Suppression. If the selected unit is a friendly unit with Suppressed X, roll 2D3 and worsen X equal to the result.</characteristic>
              </characteristics>
            </profile>
            <profile name="5 or 6 Divination" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="dcd9-1a32-8930-95d0">
              <characteristics>
                <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">The next time you roll for initiative, if this unit has an ASTROPATH model, instead of rolling 2D6 roll 6+D6 for that initiative roll.</characteristic>
              </characteristics>
            </profile>
          </profiles>
        </selectionEntry>
      </selectionEntries>
