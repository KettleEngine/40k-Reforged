            <profile name="Ghostlight" typeId="2dff-53d0-6d25-8c59" typeName="Weapon" hidden="false" id="c0d4-7860-0e7b-2714">
              <characteristics>
                <characteristic name="Tp" typeId="6c1c-7d1d-c8b0-33ec">Hv</characteristic>
                <characteristic name="A" typeId="13c5-f234-c120-afc3">1</characteristic>
                <characteristic name="WS" typeId="459f-6890-e77f-b62f">3+</characteristic>
                <characteristic name="S" typeId="571c-0471-2614-c57c">6</characteristic>
                <characteristic name="D" typeId="c2c0-3714-05e2-65a0">2D3+6</characteristic>
                <characteristic name="Abilities" typeId="d93f-70ee-72bc-5ef9">Velocity, Breach, While selecting a target for this weapon, you may select an enemy unit up 40” away instead of 32”.</characteristic>
              </characteristics>
            </profile>
            <profile name="Ghostlight" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="4e9c-5603-3ac9-ea86">
              <characteristics>
                <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After this unit’s Move step, if there are two or more models in this unit with either a Prism Rifle or Prism Blaster, you may have this unit ‘combine beams’. If you do, until the End step, each model in this unit loses its Prism Blaster and Prism Rifle weapons, and one model of your choice gains the Ghostlight weapon.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <infoLinks>
            <infoLink name="Velocity" id="46df-6416-88dc-c0dc" hidden="false" type="rule" targetId="5e3c-8b11-830c-6d2a"/>
            <infoLink name="Breach" id="2c15-91bb-332b-243a" hidden="false" type="rule" targetId="265b-df47-6a5e-4d1c"/>
          </infoLinks>
        </selectionEntry>
      </selectionEntries>
      <profiles>
        <profile name="Holo-Fields" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="f2ca-d9c3-0db2-ff85">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">For each wound a model in this unit is selected to suffer, if the unit which made that attack is further than 12” away, roll a D6. On a 5+, that attack fails.</characteristic>
          </characteristics>
        </profile>
        <profile name="Eternal Duty" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="f32a-3950-b7e1-0a1f">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">For each attack made by this unit that targets a unit with Fatal Thread, add 1 to the Hit Roll of that attack.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Relics (Reference)" hidden="false" id="81b3-1ebe-3f72-c7bf" sortIndex="-3">
      <categoryLinks>
        <categoryLink name="Configuration" hidden="false" id="f048-e4ad-4be8-0d55" targetId="9cd6-0442-3f35-6b52" primary="true"/>
      </categoryLinks>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="force" shared="true" id="6ea7-4439-5ad4-86a1" includeChildSelections="false"/>
        <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="6c30-cb33-e760-fa66-min" includeChildSelections="false"/>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="6c30-cb33-e760-fa66-max" includeChildSelections="false"/>
      </constraints>
      <profiles>
        <profile name="1 Blood Moon of Khaine" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="6be5-4d96-d9ca-1370">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">For each ranged attack made for this unit, a Wound Roll of 5+ causes an additional wound. If the target unit of those attacks has Fatal Thread, reroll a Wound Roll of 1 for that attack.</characteristic>
          </characteristics>
        </profile>
        <profile name="2 Webway Loom" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="4f48-1df1-4fd2-d115" noindex="false">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit gains this ability, select two points on the battlefield within 16” of this unit and mark those points. While this unit has this ability, after any of your units Activate within 4” of that point, you may remove your active unit from the battlefield. Then, Deploy your active unit wholly within 6” of the other selected point.</characteristic>
          </characteristics>
        </profile>
        <profile name="3 Farseer Spirit Stone" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="a73b-cff7-f2ed-f0e7">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">This unit gains Psyker 3.</characteristic>
          </characteristics>
        </profile>
        <profile name="5 Vauls’ Blessing" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="428e-170c-f3ba-f8ae">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">For each melee attack made for this unit, a Hit Roll of 5+ for that attack causes an additional hit. If the target unit of those attacks has Fatal Thread, reroll a Hit Roll of 1 for that attack.</characteristic>
          </characteristics>
        </profile>
        <profile name="4 Faolchu’s Wing" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="9567-4b7f-ec24-af3d">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit&apos;s Attacks step, it may Reposition.</characteristic>
          </characteristics>
        </profile>
        <profile name="6 Exarch Spirit Stone" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="4192-00a1-633b-7b44">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">For each attack made for this unit, a Hit Roll of 6 for that attack causes an additional hit. Additionally, if this is your second turn in a row, for each attack made for the active unit, reroll a Hit Roll of 1 for that attack.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
