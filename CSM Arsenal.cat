          </modifiers>
        </profile>
        <profile name="Iron Armoury (Shrapnel Boltguns)" typeId="2dff-53d0-6d25-8c59" typeName="Weapon" hidden="true" id="620b-eaf7-d3c6-26bd">
          <characteristics>
            <characteristic name="Tp" typeId="6c1c-7d1d-c8b0-33ec">Aslt</characteristic>
