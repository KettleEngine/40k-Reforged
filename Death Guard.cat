      </categoryLinks>
      <profiles>
        <profile name="1 Sapping Lantern" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="7abc-0ab4-73fe-c47e">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After an enemy unit Activates within 14” of this unit, until the End step, that unit may only move up to 3”.</characteristic>
          </characteristics>
        </profile>
        <profile name="2 Tolling Bell" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="f8fe-0314-3589-cffd">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After an enemy unit Activates within 14” of this unit, that unit suffers 3D3 Suppression.</characteristic>
          </characteristics>
        </profile>
        <profile name="4 Putrid Pustules" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="bab7-714b-4fe4-0b84">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">This unit gains Resilient 5+ and you may reroll Resilient rolls made for this unit.</characteristic>
          </characteristics>
        </profile>
        <profile name="6 Cornucopia of Corruption" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="5664-e1ae-fac5-44ac">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit’s Move step, all enemy units within 7” suffers 3D3 Suppression. Then, all enemy units within 7” of this unit and Suppressed X, that unit suffers SW equal to X+D3.</characteristic>
          </characteristics>
        </profile>
        <profile name="5 Sigil of Decay" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="2c28-da20-4303-09e5">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">For each attack made for this unit’s weapons with Plague or Putrid, and reroll a failed Wound Roll for that attack.</characteristic>
          </characteristics>
        </profile>
        <profile name="3 Plague Skull of Glothila" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="05b2-650f-a77f-1134">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit Activates, select one model in this unit. Until the End step, the selected model gains the following weapon:</characteristic>
          </characteristics>
        </profile>
        <profile name="3 Plague Skull of Glothila (Weapon)" typeId="2dff-53d0-6d25-8c59" typeName="Weapon" hidden="false" id="c1cf-fe3d-c80b-4223">
          <characteristics>
            <characteristic name="Tp" typeId="6c1c-7d1d-c8b0-33ec">CQ</characteristic>
            <characteristic name="A" typeId="13c5-f234-c120-afc3">1</characteristic>
            <characteristic name="WS" typeId="459f-6890-e77f-b62f">2+</characteristic>
            <characteristic name="S" typeId="571c-0471-2614-c57c">7</characteristic>
            <characteristic name="D" typeId="c2c0-3714-05e2-65a0">1</characteristic>
            <characteristic name="Abilities" typeId="d93f-70ee-72bc-5ef9">Blast 7, Putrid, Plague, Indirect</characteristic>
          </characteristics>
        </profile>
      </profiles>
