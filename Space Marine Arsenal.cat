          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">This unit gains Resilient 5+. After this unit&apos;s Attacks step, each enemy unit within 3D6” suffers 2 SW. If those units are within 6” they suffer an additional 2 SW.</characteristic>
          </characteristics>
          <modifiers>
