      <profiles>
        <profile name="1 Banner of da WAAAAGH" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="a56e-10fa-376f-adea">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">For each attack any of your units make which targets an enemy unit within 8” of this unit, a Wound Roll of 6 causes an additional wound.</characteristic>
          </characteristics>
        </profile>
        <profile name="2 Fixa Uppaz" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="ed7b-3683-a162-bc33">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit’s Move step, select a friendly vehicle unit within 6” of this unit. The selected unit Heals 2D3. Then, for each Health restored, each enemy vehicle unit within 12” of this unit suffers that many SW.</characteristic>
          </characteristics>
        </profile>
        <profile name="4 Ain&apos;t Bovvered" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="234a-ef62-2c27-dd86">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">While this unit has this ability, you may reroll Resilient rolls made for this unit.</characteristic>
          </characteristics>
        </profile>
        <profile name="6 Dakka-Dakka-Dakka-Dakka" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="01a3-f1c6-af51-8b96">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">For each ranged attack made by this unit, a Hit Roll of 6 for that attack causes 2 additional hits.</characteristic>
          </characteristics>
        </profile>
        <profile name="5 Ol’ Boss’s Pincha" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="6083-acfc-331f-05bf">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit Activates, select one model in this unit. Until the End step, the selected model gains the following weapon</characteristic>
          </characteristics>
        </profile>
        <profile name="3 ‘UGE Choppa" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="false" id="f798-c939-ee7e-759a">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit Activates, select one model in this unit. Until the End step, the selected model gains the following weapon:</characteristic>
          </characteristics>
        </profile>
        <profile name="5 Ol’ Boss’s Pincha" typeId="2dff-53d0-6d25-8c59" typeName="Weapon" hidden="false" id="d377-e042-53de-4436">
