    <selectionEntry type="upgrade" import="true" name="Psychic Powers (Reference)" hidden="false" id="aa32-ae3b-7939-cce1" sortIndex="-3">
      <constraints>
        <constraint type="max" value="1" field="selections" scope="force" shared="true" id="6135-94e8-b462-bd67" includeChildSelections="false"/>
        <constraint type="min" value="1" field="selections" scope="force" shared="true" id="5b6b-e374-f855-1414" includeChildSelections="false"/>
        <constraint type="max" value="1" field="selections" scope="force" shared="true" id="14b8-80b4-c165-f1cd" includeChildSelections="false"/>
      </constraints>
      <categoryLinks>
        <categoryLink name="Configuration" hidden="false" id="6a37-e6d0-5cea-f4c5" targetId="9cd6-0442-3f35-6b52" primary="true"/>
      </categoryLinks>
      <profiles>
        <profile name="1 Putrid Miasma" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="f5f3-5aaa-ce96-b226">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select a friendly unit within 14” of this unit. Until the next time this unit is Activated or dies, ranged attacks that target the selected unit have a -1 penalty to their Hit Roll. Attacks cannot be affected by this psychic power more than once.</characteristic>
          </characteristics>
        </profile>
        <profile name="2 Blighted Pathogens" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="440d-3cb4-6bfd-c916">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select any friendly unit within 14” of this unit. Until the next time this unit is Activated or dies, enemy units within 14” of the selected unit gain Nurgle’s Fruit.</characteristic>
          </characteristics>
        </profile>
        <profile name="3 Gift of Contagion" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="e894-0d5a-083d-c75b">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select one enemy unit within 14” of this unit. Then, that unit and each enemy unit within 7” of that unit suffer X Suppression equal to the selected unit’s Suppression X.</characteristic>
          </characteristics>
        </profile>
        <profile name="4 Curse of the Leper" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="6a08-bd43-c199-35cb">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select an enemy unit within 14” of this unit. The selected unit suffers 3D6 Suppression.</characteristic>
          </characteristics>
        </profile>
        <profile name="5 Bubotic Vitality" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="bf41-f1d8-6eea-f888">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select one friendly unit within 14” of this unit. Until the next time this unit is Activated or dies, the selected unit gains Resilient 5+ and you may reroll Resilient rolls made for this unit.</characteristic>
          </characteristics>
        </profile>
        <profile name="6 Path of the Plaguebearers" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="129f-7968-3d0c-6958">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select one friendly unit within 14” of this unit. Until the next time this unit is Activated or dies, the selected unit’s M is improved by 3 and it may move through enemy units and terrain as if they were not there.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <infoLinks>
        <infoLink name="Suppressive (X)" id="8ed9-cf1a-2baa-0078" hidden="false" type="rule" targetId="aed3-e154-8fa2-5378"/>
        <infoLink name="Resilient (X)" id="b304-9670-943c-b044" hidden="false" type="rule" targetId="253c-c1fa-d29d-d21e"/>
      </infoLinks>
    </selectionEntry>
