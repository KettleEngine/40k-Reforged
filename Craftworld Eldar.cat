    <selectionEntry type="upgrade" import="true" name="Psychic Powers (Refrence)" hidden="false" id="cb57-8ddf-8547-48b1">
      <profiles>
        <profile name="1. Song of Souls" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="5661-15c3-120e-477f">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select a friendly unit on the battlefield. The selected unit Heals D3 and its M is improved by 2 until the end of the battle round. Then, if the selected unit has Wraithbone, it Heals D3.</characteristic>
          </characteristics>
        </profile>
        <profile name="2. Woven Webway" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="ac7f-83f6-9d25-2ea0">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select up to two obstacle or structure terrain pieces within 24” of this unit. Until the end of the battle round, after you Activate an infantry unit in reserves or one of your infantry units finishes a March within 3” of one of the selected terrain pieces, you may remove your active unit from the battlefield. Then, Deploy that unit wholly within 6” of one of the selected terrain pieces at least 9&quot; away from enemy models.</characteristic>
          </characteristics>
        </profile>
        <profile name="3. Combinatorial Foresight" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="e5c9-9797-3640-40c2">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Until the next time this unit is Activated, for each attack that targets a friendly unit within 12” of and visible to this unit, you may change the Sv of this unit to 5+++ for that attack.</characteristic>
          </characteristics>
        </profile>
        <profile name="4. Eldritch Bolt" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="4d29-91e4-ba19-e9ab">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select one unit within 16” and visible to this unit. That unit suffers 2D3 Psychic SW.</characteristic>
          </characteristics>
        </profile>
        <profile name="5. Eldritch Storm" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="d24c-86a1-6524-c6a0">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Select one point on the battlefield within 24&quot; of this unit. For each unit within 3D6” of that point, that unit suffers 2 Psychic SW.</characteristic>
          </characteristics>
        </profile>
        <profile name="6. Battle Meditations" typeId="6406-cf2b-ec5b-c7e6" typeName="Psychic Power" hidden="false" id="d934-e5eb-df8a-5194">
          <characteristics>
            <characteristic name="Description" typeId="4b9e-dc73-b312-b42d">Roll Strands of Fate 6.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <categoryLinks>
        <categoryLink name="Configuration" hidden="false" id="cd84-103a-aa64-1bca" targetId="9cd6-0442-3f35-6b52" primary="true"/>
      </categoryLinks>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="force" shared="true" id="7e06-c05a-ba1c-8d45" includeChildSelections="false"/>
      </constraints>
    </selectionEntry>
