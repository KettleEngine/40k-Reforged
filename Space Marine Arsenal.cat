        <profile name="6 Strategic Contingency" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="true" id="5fd9-d572-7187-ef29">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit is Activated, if it is an infantry unit, you may remove it from the battlefield. Then, it Heals D3+1. Then, Deploy this unit wholly within your deployment zone. Then, you may select a doctrine ability and this unit loses this relic.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="22ae-1fb4-b388-d475" shared="true" includeChildSelections="true" childName="Ultramarines"/>
              </conditions>
            </modifier>
          </modifiers>
          <comment>Ultramarines</comment>
        </profile>
        <profile name="5 Special Bolt Requisition" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="true" id="a370-badb-1f90-9bd6">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit is Activated, select one model in this unit equipped with a weapon with ‘bolt’ in its name. Then, select one of the following weapons and until the End step, the selected model gains that weapon:</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
