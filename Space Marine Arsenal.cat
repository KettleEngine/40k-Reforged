        <profile name="3 Helm of Varthion" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="true" id="ad21-4381-6942-20a8">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">While this unit is ready, after each of your End steps, if this was not your second turn in a row, you may take another turn and you must select this unit to activate that turn. If you do, during that turn, for each attack made for this unit, a Hit Roll of 6 for that attack causes an additional hit.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="22ae-1fb4-b388-d475" shared="true" includeChildSelections="true" childName="Ultramarines"/>
              </conditions>
            </modifier>
          </modifiers>
          <comment>Ultramarines</comment>
        </profile>
        <profile name="2 Medicae Supply Line" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="true" id="a4cd-2dc6-5828-2d61">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit is Activated, you may draw a line from any point on the edge of your deployment zone to any point on the edge of the enemy deployment zone. Then roll D3+2, and any number of friendly units that line passes through Heal any amount of your choice, with the total amount they Heal not exceeding that roll.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="22ae-1fb4-b388-d475" shared="true" includeChildSelections="true" childName="Ultramarines"/>
              </conditions>
            </modifier>
          </modifiers>
          <comment>Ultramarines</comment>
        </profile>
