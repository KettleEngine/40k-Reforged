      <profiles>
        <profile name="Disruptive Wavelengths" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="5c85-be5c-8500-3fe4">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After this unit is Activated in reserves, you may ‘infiltrate’. If you do, roll 2D6+1. Then, Deploy this unit anywhere on the battlefield at least X” away from all enemy units where X is the result of that roll. If you do, this unit cannot March or Fall Back this turn.</characteristic>
          </characteristics>
        </profile>
        <profile name="Electromagnetic Assault" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="ee63-aa6f-3c5e-63df">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">For each Resolve Test made for an enemy unit within 12”, worsen the result of that Resolve Test by 1.</characteristic>
          </characteristics>
