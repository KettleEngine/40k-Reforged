          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">For this unit’s Forward Deployment roll, that roll is 4D6 instead of 2D6.</characteristic>
          </characteristics>
        </profile>
        <profile name="Ge’ Closa" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="b824-1eb3-9cb9-d369">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">For each attack made by this unit that targets an enemy unit within 8” of this unit, reroll a Wound Roll of 1 for that attack.</characteristic>
          </characteristics>
        </profile>
        <profile name="An’ Sneekin’" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="06c9-a620-094a-ee48">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">For each attack that targets this unit, if this unit is in cover for that attack, the Saving Throw of that attack is improved by 1.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="Grabbin’ Klaw" hidden="false" id="9653-59f2-c308-9027">
