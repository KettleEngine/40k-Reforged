              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="Kill Them Slowly" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="true" id="1fca-a8e8-d81c-ae59">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After any of your infantry units is Activated, you may have each weapon equipped to models of that unit with Shred lose Shred and gain Suppressive X, where X is equal to that weapon&apos;s D.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="1fa8-6666-7875-be1b" shared="true" includeChildSelections="true" childName="Night Lords"/>
              </conditions>
            </modifier>
          </modifiers>
          <comment>Night Lords</comment>
        </profile>
      </profiles>
