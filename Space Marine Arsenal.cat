      <costs>
        <cost name="pts" typeId="points" value="110"/>
      </costs>
      <profiles>
        <profile name="Infiltrate Enemy Lines" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="a7b5-2537-517b-651b">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After this unit is Activated in reserves, you may ‘infiltrate’. If you do, roll 2D6+1. Then, Deploy this unit anywhere on the battlefield at least X” away from all enemy units where X is the result of that roll. Then, during this turn&apos;s Move step, do not make a Move Roll and this unit cannot Advance or Reposition.</characteristic>
          </characteristics>
        </profile>
        <profile name="Scout Ahead" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="e61a-6b83-12ba-0131">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">While this unit is visible to one or more units with Battle-Brothers, this unit gains that unit&apos;s doctrine ability.</characteristic>
          </characteristics>
        </profile>
        <profile name="Hostile Territory" typeId="e9b6-89e0-ffee-5662" typeName="Ability" hidden="false" id="59aa-a436-6c95-4f13">
          <characteristics>
            <characteristic name="Description:" typeId="22b9-735d-71b1-6d7a">After this unit’s Attacks step, this unit may Reposition up to XD3” where X is equal to the number of different enemy units within 12” of this unit.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
