            <characteristic name="Abilities" typeId="d93f-70ee-72bc-5ef9">Holy Trinity</characteristic>
          </characteristics>
        </profile>
        <profile name="Saintly Flamer" typeId="2dff-53d0-6d25-8c59" typeName="Weapon" hidden="false" id="7514-e404-c6d6-015e">
          <characteristics>
            <characteristic name="Tp" typeId="6c1c-7d1d-c8b0-33ec">CQ</characteristic>
            <characteristic name="A" typeId="13c5-f234-c120-afc3">12</characteristic>
            <characteristic name="WS" typeId="459f-6890-e77f-b62f">4+</characteristic>
