      </categoryLinks>
      <profiles>
        <profile name="3 Cloak of Conquests" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="true" id="c0cf-c50c-d3f0-523a">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">This unit gains Resilient 6+. Once, after this unit captures a vault, improve its Resilient X+ by 1. Once, after this unit destroys an enemy unit, improve its Resilient X+ by 1.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="4664-cd3f-b95b-a458" shared="true" includeChildSelections="true" childName="Black Legion"/>
              </conditions>
            </modifier>
          </modifiers>
          <comment>Black Legion</comment>
        </profile>
        <profile name="2 Spineshiver Blade" typeId="2dff-53d0-6d25-8c59" typeName="Weapon" hidden="true" id="de77-e8b2-9508-5523">
          <characteristics>
            <characteristic name="Tp" typeId="6c1c-7d1d-c8b0-33ec">ML</characteristic>
            <characteristic name="A" typeId="13c5-f234-c120-afc3">4</characteristic>
            <characteristic name="WS" typeId="459f-6890-e77f-b62f">1+</characteristic>
            <characteristic name="S" typeId="571c-0471-2614-c57c">7</characteristic>
            <characteristic name="D" typeId="c2c0-3714-05e2-65a0">2</characteristic>
            <characteristic name="Abilities" typeId="d93f-70ee-72bc-5ef9">Shred</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="4664-cd3f-b95b-a458" shared="true" includeChildSelections="true" childName="Black Legion"/>
              </conditions>
            </modifier>
          </modifiers>
          <comment>Black Legion</comment>
        </profile>
        <profile name="6 Despoil Dominion" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="true" id="a3fb-57ec-838a-7c1f">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After a unit gains this ability, select one of the vaults. While this unit has this unit ability, enemy units within 16” of that vault gain Ruinous Onslaught. After any of your units capture the selected vault, you may ‘desolate the realm’. If you do, that vault cannot be captured again in this battle.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="4664-cd3f-b95b-a458" shared="true" includeChildSelections="true" childName="Black Legion"/>
              </conditions>
            </modifier>
          </modifiers>
          <comment>Black Legion</comment>
        </profile>
        <profile name="5 United In Hatred" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="true" id="7abf-5b82-3deb-e8b7">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">While this unit is not active, each enemy unit visible to it gains Dark Gods’ Hatred. If any of those units are within 16” of one or more of your units with Traitorous Contempt, instead those units gain Ruinous Onslaught.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="4664-cd3f-b95b-a458" shared="true" includeChildSelections="true" childName="Black Legion"/>
              </conditions>
            </modifier>
          </modifiers>
          <comment>Black Legion</comment>
        </profile>
        <profile name="4 Lupercal’s Doctrine" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="true" id="1ae8-9f26-46dc-09db">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">While this unit is within 12” of an enemy leader unit, for each attack made for this unit, reroll a failed Hit Roll for that attack. After this unit destroys an enemy leader unit, it may Advance.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="4664-cd3f-b95b-a458" shared="true" includeChildSelections="true" childName="Black Legion"/>
              </conditions>
            </modifier>
          </modifiers>
          <comment>Black Legion</comment>
        </profile>
        <profile name="1 Misery of the Meek" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="true" id="5787-f694-ed44-07d1">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">While an enemy unit with Suppressed is within 16&quot; of this unit, this unit gains Resilient 5+.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="1fa8-6666-7875-be1b" shared="true" includeChildSelections="true" childName="Night Lords"/>
              </conditions>
            </modifier>
          </modifiers>
          <comment>Night Lords</comment>
        </profile>
        <profile name="2 Spineshiver Blade" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="true" id="6128-03bc-b89e-466a">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit is Activated, select one model in this unit. Until the End step, the selected model gains the following weapon:</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="4664-cd3f-b95b-a458" shared="true" includeChildSelections="true" childName="Black Legion"/>
              </conditions>
              <comment>Black Legion</comment>
            </modifier>
          </modifiers>
          <comment>Black Legion</comment>
        </profile>
        <profile name="1 Techno-Venomous Mechatendrils" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="true" id="c3fb-b82f-ad88-abbc">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit gains this ability or after this unit’s Move step, select one of your units within 6”. The selected unit Repairs 2D3.</characteristic>
          </characteristics>
          <comment>Iron Warriors</comment>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="27b0-cf36-cd17-73c6" shared="true" includeChildSelections="true" childName="Iron Warriors"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="6 Thunderburst Towed Artillery" typeId="2dff-53d0-6d25-8c59" typeName="Weapon" hidden="true" id="1f9b-a7d1-39e5-0f7b">
          <characteristics>
            <characteristic name="Tp" typeId="6c1c-7d1d-c8b0-33ec">Hv</characteristic>
            <characteristic name="A" typeId="13c5-f234-c120-afc3">3</characteristic>
            <characteristic name="WS" typeId="459f-6890-e77f-b62f">5+</characteristic>
            <characteristic name="S" typeId="571c-0471-2614-c57c">8</characteristic>
            <characteristic name="D" typeId="c2c0-3714-05e2-65a0">1</characteristic>
            <characteristic name="Abilities" typeId="d93f-70ee-72bc-5ef9">Indirect, Barrage, Blast 3, Suppressive 1</characteristic>
          </characteristics>
          <comment>Iron Warriors</comment>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="27b0-cf36-cd17-73c6" shared="true" includeChildSelections="true" childName="Iron Warriors"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="5 Destruction Doctrine" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="true" id="838a-3dec-273a-de0d">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit finishes an Advance, you may select a visible piece of terrain. All enemy units within 2” of the selected terrain piece suffer D6+1 SW. If any of your models within 24” of and visible to the selected terrain piece is equipped with a Hv weapon, those enemy units suffer 2D6+1 SW instead. Then, if there are no enemy models on that terrain piece, remove it from the battlefield.</characteristic>
          </characteristics>
          <comment>Iron Warriors</comment>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="27b0-cf36-cd17-73c6" shared="true" includeChildSelections="true" childName="Iron Warriors"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="4 Siegebreaker Mace" typeId="2dff-53d0-6d25-8c59" typeName="Weapon" hidden="true" id="3435-1ee6-a36e-c1e3">
          <characteristics>
            <characteristic name="Tp" typeId="6c1c-7d1d-c8b0-33ec">ML</characteristic>
            <characteristic name="A" typeId="13c5-f234-c120-afc3">3</characteristic>
            <characteristic name="WS" typeId="459f-6890-e77f-b62f">3+</characteristic>
            <characteristic name="S" typeId="571c-0471-2614-c57c">16</characteristic>
            <characteristic name="D" typeId="c2c0-3714-05e2-65a0">2D3+1</characteristic>
            <characteristic name="Abilities" typeId="d93f-70ee-72bc-5ef9">Breach, This unit may move over terrain as if they were not there. 


Once per turn, after a successful Wound Roll for an attack made for this weapon, select another enemy unit within 6” of and visible to the target unit of that attack. The selected enemy unit suffers 1+2D3 SW.</characteristic>
          </characteristics>
          <comment>Iron Warriors</comment>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="27b0-cf36-cd17-73c6" shared="true" includeChildSelections="true" childName="Iron Warriors"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="3 Hindering Mecha-Serpents" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="true" id="772f-e68a-8f51-8a10">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit&apos;s Move step, select one enemy unit within 16&quot; of and visible to this unit. That unit suffers 3D6+8 Suppression, and gains the following ability:

Constricted: For each Move Roll made for this unit, roll 1 less D6 for that roll. If this unit does not have Suppressed, it loses this ability.</characteristic>
          </characteristics>
          <comment>Iron Warriors</comment>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="27b0-cf36-cd17-73c6" shared="true" includeChildSelections="true" childName="Iron Warriors"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="2 Fleshmetal Exoskeleton" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="true" id="2fcc-1ceb-d971-87cd">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">This unit gains Resilient 6+. After this unit’s Attacks step, this unit Repairs D3.</characteristic>
          </characteristics>
          <comment>Iron Warriors</comment>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="27b0-cf36-cd17-73c6" shared="true" includeChildSelections="true" childName="Iron Warriors"/>
              </conditions>
            </modifier>
          </modifiers>
        </profile>
        <profile name="1 Drakescale Plate" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="true" id="b1c5-1955-2ce4-b73f">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">This unit gains Resilient 5+.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="d592-5a78-0580-1d03" shared="true" includeChildSelections="true" childName="Alpha Legion"/>
              </conditions>
            </modifier>
          </modifiers>
          <comment>Alpha Legion</comment>
        </profile>
        <profile name="6 Bereft of Mercy" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="true" id="6835-d6ca-cd7d-647e">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit’s Attacks step, if any enemy models in a unit with Suppressed X within engagement range of this unit died this turn, each enemy unit within 12&quot; of and visible to that enemy unit suffers X Suppression. After an enemy unit with Suppressed X within engagement range of this unit is destroyed by an attack made for this unit, each enemy unit within 24&quot; of this unit suffers X Suppression.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="1fa8-6666-7875-be1b" shared="true" includeChildSelections="true" childName="Night Lords"/>
              </conditions>
            </modifier>
          </modifiers>
          <comment>Night Lords</comment>
        </profile>
        <profile name="5 Talons of the Night Terror" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="true" id="c8b9-7071-aa05-ca47">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit&apos;s Move step, each enemy infantry unit within engagement range of this unit suffers 2D3 Suppression. Then, for each enemy unit within engagement range of this unit, that unit suffers X SW where X is equal to that unit&apos;s Suppressed X.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="1fa8-6666-7875-be1b" shared="true" includeChildSelections="true" childName="Night Lords"/>
              </conditions>
            </modifier>
          </modifiers>
          <comment>Night Lords</comment>
        </profile>
        <profile name="4 Vox Daemonicus" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="true" id="a6d6-229f-a5e4-512a">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">Select a visible enemy unit within 8” and roll 3D3. That roll is X. Then, select a second enemy unit within X&quot; of and visible to the first, and a third within X&quot; of and visible to the second, and so on for any number of enemy units. Each enemy unit can only be selected once, and you can stop selecting at any time. Then, each selected unit suffers D3+2 Suppression.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="1fa8-6666-7875-be1b" shared="true" includeChildSelections="true" childName="Night Lords"/>
              </conditions>
            </modifier>
          </modifiers>
          <comment>Night Lords</comment>
        </profile>
        <profile name="3 Stormbolt Plate" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="true" id="af1c-0119-5f80-a94c">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After the End step of your turns, if this unit is within 12” of an enemy unit with Suppressed, this unit may Reposition.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="1fa8-6666-7875-be1b" shared="true" includeChildSelections="true" childName="Night Lords"/>
              </conditions>
            </modifier>
          </modifiers>
          <comment>Night Lords</comment>
        </profile>
        <profile name="2 Claws of the Black Hunt" typeId="2dff-53d0-6d25-8c59" typeName="Weapon" hidden="true" id="fd35-db01-833b-ef04">
          <characteristics>
            <characteristic name="Tp" typeId="6c1c-7d1d-c8b0-33ec">ML</characteristic>
            <characteristic name="A" typeId="13c5-f234-c120-afc3">8</characteristic>
            <characteristic name="WS" typeId="459f-6890-e77f-b62f">2+</characteristic>
            <characteristic name="S" typeId="571c-0471-2614-c57c">4</characteristic>
            <characteristic name="D" typeId="c2c0-3714-05e2-65a0">1</characteristic>
            <characteristic name="Abilities" typeId="d93f-70ee-72bc-5ef9">Shred, Pierce For each attack made for this weapon which targets a unit with Suppressed, add 1 to the Hit Roll of that attack.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="1fa8-6666-7875-be1b" shared="true" includeChildSelections="true" childName="Night Lords"/>
              </conditions>
            </modifier>
          </modifiers>
          <comment>Night Lords</comment>
        </profile>
        <profile name="1 Crucible of Lies" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="true" id="1407-a376-a9d8-2ce9">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">For each attack that targets this unit, the Hit Roll of that attack is worsened by 1.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="4664-cd3f-b95b-a458" shared="true" includeChildSelections="true" childName="Black Legion"/>
              </conditions>
            </modifier>
          </modifiers>
          <comment>Black Legion</comment>
        </profile>
        <profile name="6 Sleeper Agents" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="true" id="9c56-3dd9-be17-417f">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit’s Move step, you may ‘Activate Sleeper Agents’. If you do, select an enemy infantry unit within 6” of this unit. The selected enemy unit loses X Health, where X is equal to its worst Sv (if the unit has a 4+ Save, X is 4). Then, return a number of this unit’s dead models to this unit equal to the number of enemy models that died. You may only ‘Activate Sleeper Agents’ once per battle.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="d592-5a78-0580-1d03" shared="true" includeChildSelections="true" childName="Alpha Legion"/>
              </conditions>
            </modifier>
          </modifiers>
          <comment>Alpha Legion</comment>
        </profile>
        <profile name="5 Shadeblade" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="true" id="4fdb-3b61-1798-2e41">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">While this unit is ready, for each attack that targets it from a model more than 8” away, worsen the Hit Roll of that attack by 1. After this unit is Activated, select one model in this unit. Until the End step, the selected model gains the following weapon:</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="d592-5a78-0580-1d03" shared="true" includeChildSelections="true" childName="Alpha Legion"/>
              </conditions>
            </modifier>
          </modifiers>
          <comment>Alpha Legion</comment>
        </profile>
        <profile name="4 Denial Contingency" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="true" id="4d20-c7a5-0a17-a247">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After an enemy unit without Fly finishes an Advance visible to and within 24” of this unit, roll a D6; if that unit advanced this turn, add 1 to the result. On a 5+, make attacks with the following weapon targeting that unit and this unit cannot use this ability again this battle round.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="d592-5a78-0580-1d03" shared="true" includeChildSelections="true" childName="Alpha Legion"/>
              </conditions>
            </modifier>
          </modifiers>
          <comment>Alpha Legion</comment>
        </profile>
        <profile name="3 Mindveil" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="true" id="048d-cccb-d447-531d">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After an enemy unit finishes an Advance visible to this unit, you may roll a D6. On a 5+, this unit may Reposition, and may move through enemy models and terrain as if they were not there while doing so.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="d592-5a78-0580-1d03" shared="true" includeChildSelections="true" childName="Alpha Legion"/>
              </conditions>
            </modifier>
          </modifiers>
          <comment>Alpha Legion</comment>
        </profile>
        <profile name="2 Hydra&apos;s Wail" typeId="9b56-9768-f88b-14ac" typeName="Relics" hidden="true" id="f0ed-f4d6-39b1-b78d">
          <characteristics>
            <characteristic name="Description" typeId="becf-f398-aed2-688b">After this unit’s Move step, select an enemy unit visible to and within 12” of this unit. Each other enemy unit visible to that enemy unit suffers D6+6 Suppression.</characteristic>
          </characteristics>
          <modifiers>
            <modifier type="set" value="false" field="hidden">
              <conditions>
                <condition type="atLeast" value="1" field="selections" scope="force" childId="d592-5a78-0580-1d03" shared="true" includeChildSelections="true" childName="Alpha Legion"/>
              </conditions>
            </modifier>
          </modifiers>
          <comment>Alpha Legion</comment>
        </profile>
        <profile name="4 Denial Contingency (Melta Remote Mine)" typeId="2dff-53d0-6d25-8c59" typeName="Weapon" hidden="true" id="30d5-5661-e6cb-6fe1">
